@page "/plugins"
@inject IServiceProvider Sp
@inject ITrustProvider Trust

@attribute [Display(Name = "System Components", ShortName = "Plugins", GroupName = "Administration", Prompt = "bi-puzzle-fill")]


<div class="flash-card animate-in">

    <p>Status: @(IsBootstrapping ? ("Scanning Assemblies... " + Scanning) : "Ready")</p>

    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Package</th>
                <th>Path</th>
                <th>Status</th>
                <th>Enable</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                @foreach (var plugin in DiscoveredStatus ?? [])
                {
                    <td class="name-col">
                        <strong>@plugin.Title</strong>
                        <span class="product-tag">@plugin.Metadata.Company</span>
                    </td>

                    <td class="meta-col">
                        <small>Pkg: @plugin.Metadata.Package</small><br />
                        <small>Pub: @plugin.Metadata.Publisher</small>
                    </td>

                    <td class="path-col">
                        <code>@plugin.InstallPath</code>
                    </td>

                    <td class="status-col">
                        @switch (plugin.Metadata.TrustLevel)
                        {
                            case LevelOfTrust.Full: // System / Internal
                                <i class="bi bi-gem" title="System Core Component"></i>
                                break;
                            case LevelOfTrust.Trusted: // Signed but Third Party
                                <i class="bi bi-scroll" title="Digitally Trusted"></i>
                                break;
                            case LevelOfTrust.Verified: // Fully Verified / Partner
                                <i class="bi bi-shield-check" title="Verified Publisher"></i>
                                break;
                            case LevelOfTrust.Mine: 
                            case LevelOfTrust.Signed: // Community / Unsigned
                                <i class="bi bi-people" title="Community Contributed"></i>
                                break;
                            case LevelOfTrust.Published: // Local / Dev Mode
                                <i class="bi bi-tools" title="Local Development Build"></i>
                                break;
                            case LevelOfTrust.None:
                            case LevelOfTrust.Meta: // Unknown / Danger
                            default:
                                <i class="bi bi-exclamation-triangle" title="Unknown Origin"></i>
                                break;
                        }
                    </td>

                    <td class="enable-col">
                        <label class="switch">
                            <input type="checkbox" @checked="plugin.IsActive" />
                            <span class="slider"></span>
                        </label>
                    </td>
                }
            </tr>
        </tbody>
    </table>
</div>


@code {
    public static bool IsBootstrapping { get; set; } = true;

    public static Dictionary<Type, string>? DiscoveredPlugins { get; }
    public static Dictionary<Type, string>? DiscoveredTrust { get; }
    public static List<PluginContract> DiscoveredStatus { get; } = new();

    [CascadingParameter(Name = "IsStaticRender")]
    public bool IsStaticRender { get; set; }

    public record PluginContract(
        string Title,
        string InstallPath,
        bool IsTrusted,
        AssemblyInfo Metadata,
        bool IsActive);

    protected override void OnInitialized()
    {
        base.OnInitialized();
        if (IsStaticRender) return;
        DiscoveredStatus.Clear();
        _ = CheckStatus();
        _ = CheckPluginFiles();
    }

    public static List<Type> AllPlugins = [..TypeExtensions.AllRegisteredTypes
    .GetMine()
    .Where(t => t.Extends(typeof(IHasPlugins)))];

    public static List<Type> EnabledPlugins = new();


    public async Task CheckStatus()
    {
        EnabledPlugins ??= await GetEnabledPlugins(Sp);
        foreach (var plugin in EnabledPlugins)
        {
            DiscoveredStatus.Add(new PluginContract(
                        Title: plugin.Name,
                        InstallPath: plugin.Assembly.Location,
                        IsTrusted: false, //metadata?.IsTrusted ?? false,
                        Metadata: plugin.GetAssemblyInfo(),
                        IsActive: false // TODO: check if enabled
                    ));
        }

    }

    // TODO: use this on service startup? way to bootstrap another container?
    public static async Task<List<Type>> GetEnabledPlugins(IServiceProvider service)
    {
        List<Type> enabledPlugins = new();
        foreach(var plugin in AllPlugins)
        {
            var myDelegate = plugin.GetProperties(nameof(IHasPlugins.Installed)).First().GetValue(null) as Delegate;
            if (myDelegate == null || (Nullable.GetUnderlyingType(myDelegate.Method.ReturnType)
                ?? myDelegate?.Method.ReturnType)?.Extends(typeof(Task<string?>)) != true)
                throw new InvalidOperationException("IHasPlugins.Installed delegate must return a Task<string?> with the name of the setting it used to check if its installed or not" + myDelegate?.Method);
            var result = myDelegate.InvokeService(service);
            if(result is Task task) await task;
            if ((result as dynamic)?.Result != null)
                enabledPlugins.Add(plugin);
        }
        return enabledPlugins;
    }

    public static bool IsLoading { get; private set; } = false;

    private async Task RunFullScan()
    {
        if (IsLoading) return;

        IsLoading = true;
        DiscoveredStatus.Clear();
        StateHasChanged();

        // Offload the heavy file IO to a background thread to keep UI snappy
        await Task.Run(async () =>
        {
            var fileTask = CheckPluginFiles();
            var statusTask = CheckStatus();

            await Task.WhenAll(fileTask, statusTask);
        });

        IsLoading = false;
        StateHasChanged();
    }


    private static string[]? PluginFiles { get; set; } = null;
    private string? Scanning = null;

    protected async Task DebounceFilename(string? file)
    {
        Scanning = file;
        await InvokeAsync(StateHasChanged);
    }

    protected async Task CheckPluginFiles()
    {
        // TODO: refresh button
        PluginFiles ??= Directory.GetFiles(AppDomain.CurrentDomain.BaseDirectory, "*.dll", SearchOption.TopDirectoryOnly);

        // Process files in parallel batches to speed up metadata extraction
        await Parallel.ForEachAsync(PluginFiles, async (file, ct) =>
        {
            _ = TaskExtensions.Debounce<string>(DebounceFilename, 50, file);

            var metadata = await Trust.GetAssemblyInfoAsync(file);
            if (metadata == null) return;

            var contract = new PluginContract(
                Title: metadata.Product ?? System.IO.Path.GetFileNameWithoutExtension(file),
                InstallPath: file,
                IsTrusted: (int)metadata.TrustLevel > 2 || metadata.IsMine(),
                Metadata: metadata,
                IsActive: false
            );

            // Thread-safe update to the UI list
            lock (DiscoveredStatus)
            {
                DiscoveredStatus.Add(contract);
            }

            // Tell the UI to refresh as each item arrives
            await InvokeAsync(StateHasChanged);
        });
        
        IsBootstrapping = false;
        await InvokeAsync(StateHasChanged);

    }
}