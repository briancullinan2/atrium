@implements IAsyncDisposable
@implements IHasMenu
@inject NavigationManager Nav
@inject IPageManager PageManager

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-logo" @onclick="() => ToggleStudy()">
        <img width="48" height="48" src="_content/FlashCard/logo_4_trans_2.png" alt="LOGO" />
        <a class="navbar-brand">Atrium</a>
    </div>
    @if (ShouldShowChat == true)
    {
        <a @onclick="() => ToggleChat()"><span class="bi @(ShowCourse == true ? "bi-list" : Chat ? "bi-journal-bookmark" : "bi-chat")"></span></a>
    } else
    {
        <a @onclick="() => ToggleChat()"><span class="bi @(ShowCourse == true ? "" : "bi-journal-bookmark")"></span></a>
    }
</div>

<input type="checkbox" @bind="menuMode" title="Navigation menu" class="navbar-toggler" />


@if (ShowCourse == true)
{
    
}
else if (!Chat)
{
    <div id="Navlist" class="nav-scrollable menu">
        @foreach (var item in GetVisibleItems())
        {
            @RenderNavItem(item)
        }
    </div>
}
else
{
    <ChatMenu />
}

@code {

    public async Task SetMenuActivated(bool show) => await InvokeAsync(StateHasChanged);
    public bool Show(NavigationManager _) => true;
    public static string Icon { get => "bi-list"; }

    // TODO: make this a static interface on IHasMenu to make it ask for types up front
    public static List<Type> Menus = (Assembly.GetEntryAssembly() ?? Assembly.GetExecutingAssembly()).GetAssemblies().ToMenus();

    protected override void OnInitialized()
    {
        base.OnInitialized();
        ChatService.OnChatWorking += SetChat;
        ChatService.OnChatChanged += SetChatMode;
        _ = ChatService.IsWorking();
    }

    protected override async Task OnInitializedAsync()
    {
        
    }

    private void SetChat(bool? chat)
    {
        if (chat != ShouldShowChat)
        {
            ShouldShowChat = chat;
            InvokeAsync(StateHasChanged);
        }
    }

    public void SetChatMode(bool chat)
    {
        if (Chat != chat)
        {
            Chat = chat;
            InvokeAsync(StateHasChanged);
        }
    }

    public async ValueTask DisposeAsync()
    {
        ChatService.OnChatWorking -= SetChat;
        ChatService.OnChatChanged -= SetChatMode;
    }

    private void HandleClick(INavMenuItem item)
    {
        var currentUrl = Nav.ToBaseRelativePath(Nav.Uri);
        bool isOnTargetPage = string.Equals(currentUrl, item.Href.Trim('/'), StringComparison.InvariantCultureIgnoreCase);

        if(item.Children.Count() == 0 || _studyMode)
        {
            Nav.NavigateTo(item.Href);
            menuMode = false;
        }
        else if (!item.IsCollapsed)
        {
            if (isOnTargetPage)
            {
                // Rule: Only collapse if they are already on that page
                item.IsCollapsed = true;
            }
            else
            {
                // Rule: Only connect to href if it is already expanded
                Nav.NavigateTo(item.Href);
                menuMode = false;
            }
        }
        else
        {
            // If it's currently collapsed, just expand it
            item.IsCollapsed = false;
        }
    }

    public void SetStudyMode(bool study)
    {
    }

    protected void ToggleStudy()
    {
        _studyMode = !StudyService.Study;
        StudyService?.SetStudyMode(_studyMode);
    }

    protected void ToggleChat()
    {
        if (ShowCourse == true) {
            ShowCourse = false;
            InvokeAsync(StateHasChanged);
            return;
        }

        if(ShouldShowChat != true)
        {
            ShowCourse = true;
            InvokeAsync(StateHasChanged);
            return;
        }

        if(ChatService.Chat)
        {
            ShowCourse = true;
            ChatService.SetChatMode(_chatMode = false);
            // calls StateHasChanged automatically through SetChatMode
        } 
        else
        {
            ChatService.SetChatMode(_chatMode = true);
        }
    }

    RenderFragment RenderNavItem(INavMenuItem item) => __builder =>
    {
        var hasChildren = item.Children != null && item.Children.Any();

        <div class="nav-item">
            <div @onclick="() => HandleClick(item)"
                 @onclick:stopPropagation="true"
                 data-href="@item.Href">
                <HasPermission Permission="@item.RequiredPermission">
                    <NavLink class="nav-link"
                             Match="@(string.IsNullOrWhiteSpace(item.Href) ? NavLinkMatch.All : NavLinkMatch.Prefix)">

                        <span class="bi @item.Icon" aria-hidden="true"></span>
                        <span class="nav-text">@item.Title</span>

                        @if (hasChildren)
                        {
                            <span class="bi @(item.IsCollapsed ? "bi-chevron-right" : "bi-chevron-down")"></span>
                        }
                    </NavLink>
                </HasPermission>
            </div>

            @if (hasChildren && !item.IsCollapsed)
            {
                <div class="nav-children">
                    @foreach (var child in item.Children!)
                    {
                        @RenderNavItem(child)
                    }
                </div>
            }
        </div>
    };

    // This is your Iterator/List
    public static IEnumerable<INavMenuItem> MenuStructure = 
    [
        new NavMenuItem<Pages.Landing.Home>() { Title = "Home", Icon = "bi-house-door-fill" },
