@using Retheme
@inherits LayoutComponentBase
@implements IDisposable
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject IMenuService MenuService
@inject IThemeService ThemeService
@inject IStudyService StudyService
@inject ILoginService LoginService
@inject ITitleService TitleService
@inject IServiceProvider Services
@inject IPageManager PageManager
@inject IRenderStateProvider RenderState
@inject ILoggerFactory LoggerFactory
@inject IChatService ChatService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthProvider
@inject NavigationTracker Tracker

<div class="@(Background.ToString()?.ToLowerInvariant())  @(Login == true ? "login-mode" : Study == true ? "study-mode" : "") @(ShowChat == true ? "chatting" : "") @PageClass page theme-@(Application.ToString()?.ToLowerInvariant())">
    <div id="theme-sensor" style="display:none;">
        <span class="sensor-bg"></span>
        <span class="sensor-surface"></span>
        <span class="sensor-primary"></span>
        <span class="sensor-secondary"></span>
        <span class="sensor-accent"></span>
        <span class="sensor-main"></span>
        <span class="sensor-stone"></span>
        <span class="sensor-nature"></span>
        <span class="sensor-electric"></span>
        <span class="sensor-gold"></span>
    </div>

    <div class="canvas-container">
        <canvas id="lichtenbergCanvas"></canvas>
    </div>
    <div class="sidebar theme-@(Sidebar.ToString()?.ToLowerInvariant())">
        <NavMenu />
    </div>
    
    @foreach (var item in PageManager.State)
    {
        <input type="hidden" name="state_@item.Key" value="@item.Value" />
    }

    @if (ShowHeader != false)
    {
        <header class="top-row px-4">
            @if (HeaderTitle != null)
            {
                <h2>@HeaderTitle</h2>            
            }
            @if (HeaderMenu != null)
            {
                <div class="contextual-menu">
                    @HeaderMenu
                </div>
            }
            @if (HeaderMenu == null && HeaderTitle == null)
            {
                <span>&nbsp;</span>
            }
        </header>
    }
    <main>
        
        <article class="content course-container">
            @if (_previousBody != null)
            {
                <div class="flash-card @(_isTransitioning ? "animate-out" : "")">
                    @(_previousBody)
                </div>
            }
            @_activeBody
        </article>

        <ErrorBoundary @ref="_errorBoundary">
            <ChildContent>
                
            </ChildContent>
            <ErrorContent>
                <article class="content course-container">
                    <div class="flash-card hip-error-trace">
                        <h3>Something went sideways.</h3>
                        <p>the Task failed successfully.</p>
                        <button @onclick="() => _errorBoundary?.Recover()">Try Again</button>
                    
                        <pre>@_lastException?.StackTrace</pre>
                    </div>
                </article>
            </ErrorContent>
        </ErrorBoundary>


    </main>

    @if (Nav.Uri != "/error" && Nav.Uri != "/console"
        && NavigationExtensions.IdentifyNavigation(Nav.Uri).ComponentType != typeof(Pages.Shared.Console))
    {
        <RazorSharp.Pages.Shared.Console Embedded="true" />
    }

    @if (ShowChat == true)
    {
        <div class="chat-box">
            <input @onkeydown="HandleKeyDown" @bind:event="oninput" @bind="ChatMessage" type="text" placeholder="Type your message here..." /><button class="cta" @onclick="() => SendMessage()">Send</button>
        </div>
    }
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

<dialog id="components-reconnect-modal">

</dialog>

@code {
    public RenderFragment? HeaderMenu { get; private set; }
    public string? HeaderTitle { get; private set; }
    //public object? Tag { get; set; } // for comparing states for implementers
    public bool? Login { get; set; }
    public User? CurrentUser { get; set; }
    public bool? Study { get; set; }
    public string? PageClass { get; set; }
    public bool? ShowHeader { get; set; }
    public bool? ShowChat { get; set; }
    public string? ChatMessage { get; set; }
    [CascadingParameter] private ErrorBoundary? _errorBoundary { get; set; }
    private Exception? _lastException;

    /*
     * This is so fucking dumb this isn't more obvious like Nav.GetComponent(route);
     * what the fuck is Microsoft thinking?
    public Type? GetPageTypeFromUrl(string url)
    {
        // 1. Get the relative path
        var relativeUri = Nav.ToBaseRelativePath(url);

        // 2. Access the Route Options / Discovery service
        // This is the same engine the Router uses
        var routeOptions = ServiceProvider.GetRequiredService<IOptions<RazorPagesOptions>>();

        // Note: In pure WASM, you usually have to reflect into the
        // assembly to find the [Route] attributes yourself if you want
        // to bypass the Router component entirely.
