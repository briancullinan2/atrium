@inject NavigationManager Nav
@inject IRenderState Rendered
@inject IServiceProvider Service

@*what the fuck is this?*@
@if (AuthService == null)
{
    <Router AppAssembly="typeof(Layout.MainLayout).Assembly">
        <Found Context="routeData">
            @*TODO: make HasPermission log the access violations anyways?*@
            <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
            <FocusOnNavigate RouteData="routeData" Selector="h1" />
        </Found>
        <NotFound>
            @* DO NOT leave this empty or put complex logic here yet *@
            <LayoutView Layout="@typeof(Layout.MainLayout)">
                <NotFoundControl />
            </LayoutView>
        </NotFound>
    </Router>
}
else
{
<CascadingAuthenticationState>
    <Router AppAssembly="typeof(Layout.MainLayout).Assembly">
        <Found Context="routeData">
            <HasPermission RouteData="@routeData" Context="State" NotAuthorizedLayout="typeof(Layout.MainLayout)" LoadingLayout="typeof(Layout.MainLayout)">
                <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
                <FocusOnNavigate RouteData="routeData" Selector="h1" />
            </HasPermission>
        </Found>
        <NotFound>
            @* DO NOT leave this empty or put complex logic here yet *@
            <LayoutView Layout="@typeof(Layout.MainLayout)">
                <NotFoundControl />
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
}


@code
{
    protected IAuthService? FirstAuthService = null;
    protected IAuthService? AuthService { get => FirstAuthService ??= Service.GetService<IAuthService>(); }

    protected AuthenticationState? State { get; set; } = null;

    public void Dispose()
    {
        Rendered.OnEmptied -= NotifyReload;
    }

    protected override void OnInitialized()
    {
        base.OnInitialized();
        if(AuthService != null)
            NotifyReload();
        Rendered.OnEmptied += NotifyReload;
    }

    public void NotifyReload()
    {
        FirstAuthService = null;
        _ = AuthService?.GetAuthenticationStateAsync()
        .Then(async state =>
        {
            State = state;
            await InvokeAsync(StateHasChanged);
        });
    }

}