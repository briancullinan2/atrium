@inject NavigationManager Nav
@inject IAuthService AuthService
@inject IRenderState Rendered

<CascadingAuthenticationState>
    <Router AppAssembly="typeof(Layout.MainLayout).Assembly">
        <Found Context="routeData">
            <HasPermission RouteData="@routeData" Context="State" NotAuthorizedLayout="typeof(Layout.MainLayout)" LoadingLayout="typeof(Layout.MainLayout)">
                <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
                <FocusOnNavigate RouteData="routeData" Selector="h1" />
            </HasPermission>
        </Found>
        <NotFound>
            @* DO NOT leave this empty or put complex logic here yet *@
            <LayoutView Layout="@typeof(Layout.MainLayout)">
                <NotFoundControl />
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>

@code
{

    protected AuthenticationState? State { get; set; }

    public void Dispose()
    {
        Rendered.OnEmptied -= NotifyReload;
    }

    protected override void OnInitialized()
    {
        base.OnInitialized();
        Rendered.OnEmptied += NotifyReload;
    }

    public void NotifyReload()
    {
        _ = AuthService.GetAuthenticationStateAsync()
        .Then(async state =>
        {
            State = state;
            await InvokeAsync(StateHasChanged);
        });
    }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        State = await AuthService.GetAuthenticationStateAsync();
        await InvokeAsync(StateHasChanged);
    }
}