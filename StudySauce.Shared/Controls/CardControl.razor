    private bool isFlipped = false;
    private string flashClass = "";

    private void Flip() => isFlipped = true;

    private async Task HandleAnswer(Tuple<PropertyMetadata, CardsControl.ViewCard, object?> selectedValue)
    {
        ValueChanged?.InvokeAsync(selectedValue.Item3);
    }

    private async Task Next(bool wasCorrect)
    {
        //isFlipped = false;
        //await (ValueChanged?.InvokeAsync(wasCorrect) ?? Task.CompletedTask);
    }
}