@page "/settings"
@page "/settings/edit"
@page "/settings/add"
@page "/settings/list"

@implements IDisposable
@using StudySauce.Shared.Controls
@using StudySauce.Shared.Services
@using System.ComponentModel
@using System.Reflection
@using System.ComponentModel.DataAnnotations
@inject IMenuService MenuService
@inject ITitleService TitleService
@inject IFileManager FileManager
@inject NavigationManager Nav
@inject HttpClient Http
@inject IJSRuntime JS

<SyncedTitle Title="Application Settings"></SyncedTitle>

<div class="flash-card app-settings @GetDisplayClass(DataLayer.Customization.ControlMode.Edit)">
    <h2>Display Settings</h2>
    <div class="form-row">
        <span>Show animated background from packs</span>
        <input type="checkbox" />
    </div>
    <div class="form-row">
        <span>Match dark/light mode to OS</span>
        <input type="checkbox" />
    </div>
    <div class="form-row">
        <span>Dark mode</span>
        <input type="checkbox" />
    </div>
    <div class="form-row">
        <span>High contrast theme</span>
        <input type="checkbox" />
    </div>
    <div class="form-row">
        <span>Start when computer starts</span>
        <input type="checkbox" />
    </div>


    <MetadataControl Data="@([new DataLayer.Entities.Setting() {Name = "Application.Background", Value = Background.ToString()}])" TModel="DataLayer.Entities.Setting" Model="[ThemeLayout?.ElementAt(0)]" ValueChanged="@(EventCallback.Factory.Create<Tuple<PropertyMetadata, DataLayer.Entities.Setting, object?>>(this, HandleTheme))" />
    <MetadataControl Data="@([new DataLayer.Entities.Setting() {Name = "Application.Theme", Value = Application.ToString()}])" TModel="DataLayer.Entities.Setting" Model="[ThemeLayout?.ElementAt(1)]" ValueChanged="@(EventCallback.Factory.Create<Tuple<PropertyMetadata, DataLayer.Entities.Setting, object?>>(this, HandleTheme))" />
    <MetadataControl Data="@([new DataLayer.Entities.Setting() {Name = "Application.Sidebar", Value = Sidebar.ToString()}])" TModel="DataLayer.Entities.Setting" Model="[ThemeLayout?.ElementAt(2)]" ValueChanged="@(EventCallback.Factory.Create<Tuple<PropertyMetadata, DataLayer.Entities.Setting, object?>>(this, HandleTheme))" />

    <button name="themeSelect" class="cta" @onclick="() => RandomizeTheme()">Randomize Theme</button>

    <h2>Parental Controls</h2>
    <div class="form-row">
        <span>Allow child accounts to subscribe to new content</span>
        <input type="checkbox" />
    </div>


    <h2>Telemetry</h2>
    <div class="form-row">
        <span>Enable non-specific usage statistics sharing with content creators</span>
        <input type="checkbox" />
    </div>
    <div class="form-row">
        <span>Enable non-specific usage statistics sharing with hosts</span>
        <input type="checkbox" />
    </div>

    <h2><a href="@(NavigationExtensions.GetUri<Pages.Admin.Hosting>())">Hosting</a></h2>
    <div>
        <span><a href="@(NavigationExtensions.GetUri<Pages.Admin.Hosting>())">Enable hosting</a> to access your own study system from the web.</span>
    </div>
</div>


<div class="flash-card @GetDisplayClass(DataLayer.Customization.ControlMode.List)">
    <div class="settings-page">
        <label>Theme Name</label>
        <label>Background</label>
        <label>Surface</label>
        <label>Card</label>
        <label>Border</label>
        <label>Emerald</label>
        <label>Bolt</label>
        <label>Amber</label>
        <label>Compliment</label>
        <label>Text</label>
        <label>Muted</label>
        <label>Sidebar</label>
        <label>Stone</label>
        <label>Nature</label>
        <label>Electric</label>
        <label>Gold</label>
        <label>Actions</label>
        @foreach (var theme in extractedThemes ?? [])
        {
            <span class="sticky-left">@theme.ClassName.Replace("theme-", "")</span>
            @foreach(var variableKey in ThemeVariableKeys)
            {
                <span><span class="sensor" style="@(GetStyle(theme, variableKey))"></span>@theme.Variables.GetValueOrDefault(variableKey)</span>
            }
            <span></span>
        }
    </div>

    <button class="cta" @onclick="() => CopyToCSV()">Copy to CSV</button>
</div>

@code
{
    public DataLayer.Customization.ControlMode? Mode { get; set; } = DataLayer.Customization.ControlMode.Edit;
    public DataLayer.Customization.ControlMode? PreviousMode { get; set; }
    public List<Retheme.ThemeData>? extractedThemes { get; set;  } 

    private async Task CopyToCSV()
    {
        var csvBuilder = new System.Text.StringBuilder();

        // 1. Add Headers
        csvBuilder.AppendLine(string.Join("\t", themeLabels));

        // 2. Add Rows
        foreach (var theme in extractedThemes ?? [])
        {
            // Note: If data contains commas, you'd wrap values in quotes: "{item.Name}"
            csvBuilder.AppendLine("\"" + string.Join("\"\t\"", ((IEnumerable<string>)[theme.ClassName]).Concat(ThemeVariableKeys.Select(k => theme.Variables.GetValueOrDefault(k)))) + "\"");
        }

        // 3. Send to Clipboard via JS Interop
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", csvBuilder.ToString());
    }


    public string GetStyle(Retheme.ThemeData theme, string key)
    {
        return "background-color: " + theme.Variables.GetValueOrDefault(key);
    }

