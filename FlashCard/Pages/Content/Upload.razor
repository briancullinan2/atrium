@page "/upload"
@implements IDisposable
@using DataLayer.Utilities
@using DataLayer.Utilities.Extensions
@using Microsoft.EntityFrameworkCore
@using FlashCard.Controls
@using FlashCard.Services
@using System.ComponentModel
@inject IFileManager File
@inject IMenuService MenuService
@inject IServiceProvider Services
@inject IAnkiService AnkiService
@inject IQueryManager QueryManager

<SyncedTitle Title="Import Packs"></SyncedTitle>

<div class="flash-card animate-in @(isDragOver ? "dropping" : "")"
     @ondragover:preventdefault="true"
     @ondragenter:preventdefault="true"
     @ondragover="HandleDragOver"
     @ondragleave="HandleDragLeave"
     @ondrop="HandleDrop">
    <div class="drop-shader"><span class="bi bi-cloud-upload"></span><br /><span>Drop Anki Files</span></div>

    <h2>Upload Anki</h2>
    Upload pack content from Anki or spreadsheet.<br />
    <input type="text" placeholder="Search..." @bind="Search" />
    <heading class="flex-row">
        <label></label>
        <label>File Name</label>
        <label>Url</label>
        <label>Source</label>
        <label>Actions</label>
    </heading>
    <MetadataControl ValueChanged="@(EventCallback.Factory.Create<Tuple<PropertyMetadata, DataLayer.Entities.File, object?>>(this, OnAnkiSelected))" TModel="DataLayer.Entities.File" Model="@FilesLayout" Data="@Uploads?.Take(Take).ToList()"></MetadataControl>

    <div class="link-list">
        @if (!OperatingSystem.IsWindows())
        {
            <InputFile class="cta" OnChange="HandleFileSelection" />
        }
        else
        {
            <button class="btn btn-primary" @onclick="() => File.OpenFileDialog()">
                <i class="bi bi-file-earmark-plus"></i>Open File
            </button>
        }
    </div>

    <h2>Content Controls</h2>

    Import content into a group or release schedule.
    <h4>Anki Files</h4>
    <heading class="flex-row">
        <label></label>
        <label>File Name</label>
        <label>Url</label>
        <label>Source</label>
        <label>Actions</label>
    </heading>
    <MetadataControl TModel="DataLayer.Entities.File" Model="@FilesLayout" Data="@Inside?.Take(Take).ToList()"></MetadataControl>


    <h4>Converted Cards</h4>
    <heading class="flex-row">
        <label></label>
        <label>Prompt</label>
        <label>Response</label>
        <label>Type</label>
        <label>Answers</label>
        <label>Actions</label>
    </heading>
    <MetadataControl TModel="Controls.EditCardControl.EditControl" Model="@CardsLayout" Data="@CurrentCards?.Take(Take).ToList()"></MetadataControl>

</div>


@code
{
    // TODO: decide when to synchronize the file storage with memory storage
    [Category("Display")]
    public List<DataLayer.Entities.File>? Uploads { get; set; }
    public List<DataLayer.Entities.File>? AnkiSearch { get; set; }
    public IEnumerable<DataLayer.Entities.File>? Inside { get; set; }
    [Category("Content")]
    public List<Controls.EditCardControl.EditControl>? CurrentCards { get; set; }
    public IEnumerable<PropertyMetadata>? FilesLayout { get; set; }
    public IEnumerable<PropertyMetadata>? CardsLayout { get; set; }

    public int Take { get; set; } = 10;
    public int Skip { get; set; } = 0;

    protected string? _search;
    public string? Search { get => _search; set 
        {
            _search = value;        
            _ = InitAnkiSearch();
        } 
    }

    protected async Task InitAnkiSearch()
    {
        AnkiSearch = (await AnkiService.Search(Search))?.ToList();
        if (AnkiSearch == null)
        {
            return;
        }
        Uploads?.AddRange(AnkiSearch);
        await InvokeAsync(StateHasChanged);
    }

    bool isDragOver = false;

    void HandleDragOver() => File.SetDragging(true);
    void HandleDragLeave() => File.SetDragging(false);

    protected override void OnInitialized()
    {
        base.OnInitialized();
        MenuService.SetMenu(@<FlashCard.Pages.Shared.Packs />);
        FilesLayout = typeof(Pages.Content.Upload).Metadata().Categories["Display"]?.ToList();
        CardsLayout = typeof(Pages.Content.Upload).Metadata().Categories["Content"]?.ToList();
        File.OnFileDragging += OnDragging;
        _ = PopulateUploads();
    }

    protected void OnAnkiSelected(Tuple<PropertyMetadata, DataLayer.Entities.File, object?> callback)
    {
        var ankiResults = callback.Item3 as Tuple<IEnumerable<DataLayer.Entities.File>, IEnumerable<DataLayer.Entities.Card>>;
        if (ankiResults == null) return;

        Inside = ankiResults.Item1;
        CurrentCards = ankiResults.Item2.Select(c => new EditCardControl.EditControl() { Card = c }).ToList();
    }


    protected async Task PopulateUploads()
    {
        Uploads = await QueryManager.Synchronize<DataLayer.Entities.File>(f => f.Source == "Upload" || f.Source == "AnkiDownloads");
    }


    protected void OnDragging(bool dragging)
    {
        isDragOver = dragging;
        InvokeAsync(StateHasChanged);
    }

    protected async Task HandleFileSelection(InputFileChangeEventArgs e)
    {
        isDragOver = false;
        // Process the dropped files
        foreach (var file in e.GetMultipleFiles())
        {
            _ = File.UploadFile(file.OpenReadStream(), file.Name);
            // Access file properties like file.Name, file.Size, etc.
            // You can read the file stream here:
            // using var stream = file.OpenReadStream();
            // ... further processing ...
        }
        await InvokeAsync(StateHasChanged);
    }



    protected async Task HandleDrop(DragEventArgs e)
    {
        _ = File.SetDragging(false);
        // In Blazor Hybrid, e.DataTransfer.Files is usually populated
        if (e.DataTransfer.Files != null)
        {
            foreach (var file in e.DataTransfer.Files)
            {
                _ = File.UploadFile(file);
            }
        }

        await InvokeAsync(StateHasChanged);

    }



    public void Dispose()
    {
        File.OnFileDragging -= OnDragging;
    }
}
