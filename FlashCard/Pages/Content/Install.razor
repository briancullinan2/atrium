@page "/install"

@using System.Net.Http.Json
@using FlashCard.Services
@inject HttpClient Http
@inject IChatService ChatService

<SyncedTitle Title="Install AI"></SyncedTitle>


<div class="flash-card">
    Instructions for setting up <a href="https://github.com/lllyasviel/stable-diffusion-webui-forge">Automatic1111</a> and <a href="https://github.com/ggml-org/llama.cpp">llama.cpp/GGUF</a>.

    <h2>Parameter Builder</h2>

    Test the image generator and LLM with local HTTP requests.

    <div class="row">
        <div>
            <label>Load Preset</label>
            <select class="form-control" @onchange="ApplyPreset">
                <option value="">-- Select a Service --</option>
                @foreach(var preset in Services) {
                    <option value="@preset.Name">@preset.Name</option>
                }
            </select>
        </div>
        <div class="col-md-6">
            <label>Service Endpoint</label>
            <input type="text" @bind="ServiceUrl" class="form-control" placeholder="http://localhost:11434/api/generate" />
        </div>
        <div class="col-md-6">
            <label>Model Name</label>
            <input type="text" @bind="ModelName" class="form-control" placeholder="llama3" />
        </div>
        <div class="col-md-6">
            <label>API Key</label>
            <input type="text" @bind="ApiKey" class="form-control" placeholder="Api Key @(ApiKeySample)" />
        </div>

    </div>

    <button class="cta" @onclick="AddParameter">+ Add</button>
    <table class="table">
        <thead>
            <tr>
                <th>Key</th>
                <th>Type</th>
                <th>Value</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var parameter in Parameters)
            {
                <tr>
                    <td><input type="text" @bind="parameter.Key" class="form-control" /></td>
                    <td>
                        <select @bind="parameter.Type" class="form-control">
                            <option value="string">String</option>
                            <option value="number">Number</option>
                            <option value="boolean">Boolean</option>
                        </select>
                    </td>
                    <td>
                        @if (parameter.Type == "boolean") {
                            <input type="checkbox" @bind="parameter.BoolValue" />
                        } else {
                            <input type="text" @bind="parameter.Value" class="form-control" />
                        }
                    </td>
                    <td>
                        @if(Parameters.Count() > 1)
                        {
                            <button class="btn btn-danger btn-sm" @onclick="() => Parameters.Remove(parameter)">X</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <button class="cta" @onclick="ExecutePost">Send Request</button>

    <hr />
    <pre>@ResponseJson</pre>

    <h2>Recent Activity</h2>


    Usage information on what queries are being used by the application.
</div>
@code {
    private bool? IsWorking = null;
    private string ServiceUrl = "http://localhost:11434/api/generate";
    private string ModelName = "llama3";
    private string ApiKey = "";
    private string ApiKeySample = "";
    private string ResponseJson = "Result will appear here...";
    private List<DynamicParam> Parameters = new() { new DynamicParam() };
    private List<ServicePreset> Services = new();

    private void ApplyPreset(ChangeEventArgs e) {
        var preset = Services.FirstOrDefault(p => p.Name == e.Value?.ToString());
        if (preset != null) {
            ServiceUrl = preset.Url;
            ModelName = preset.DefaultModel;
            ApiKeySample = "(" + preset.ApiKey + ")";
            Parameters = preset.Params.ToList(); // Clone the list
        }
    }

    protected override void OnInitialized()
    {
        base.OnInitialized();
        _ = InitializePresets();
    }


    protected async Task InitializePresets()
    {
        Services = await ChatService.ListPresets();
        StateHasChanged();
    }

    private void AddParameter() => Parameters.Add(new DynamicParam());

    private async Task ExecutePost() {
        IsWorking = await ChatService.PingService(ServiceUrl, ModelName, ApiKey, Parameters);
    }
}