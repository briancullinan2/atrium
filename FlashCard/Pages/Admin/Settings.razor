@page "/settings"
@page "/settings/edit"
@page "/settings/add"
@page "/settings/list"

@implements IDisposable
@using DataLayer.Utilities.Extensions
@using FlashCard.Controls
@using FlashCard.Services
@using System.ComponentModel
@using System.Reflection
@using System.ComponentModel.DataAnnotations
@inject IMenuService MenuService
@inject IThemeService ThemeService
@inject ITitleService TitleService
@inject IFileManager FileManager
@inject NavigationManager Nav
@inject HttpClient Http
@inject IJSRuntime JS

<SyncedTitle Title="Application Settings"></SyncedTitle>

<div class="flash-card app-settings @GetDisplayClass(DataLayer.ControlMode.Edit)">
    <h2>Login Setting</h2>
    <div class="form-row">
        <span>Enable the Guest account.</span>
        <input type="checkbox" />
    </div>
    <div class="form-row">
        <span>Enable the Automatic Login.</span>
        <input type="checkbox" />
    </div>
    <div class="form-row">
        <span>Default user account for auto login.</span>
        @*TODO: make a user/entity select control*@
    </div>


    <h2>Display Settings</h2>
    <div class="form-row">
        <span>Show animated background from packs</span>
        <input type="checkbox" />
    </div>
    <div class="form-row">
        <span>Match dark/light mode to OS</span>
        <input type="checkbox" />
    </div>
    <div class="form-row">
        <span>Dark mode</span>
        <input type="checkbox" />
    </div>
    <div class="form-row">
        <span>High contrast theme</span>
        <input type="checkbox" />
    </div>
    <div class="form-row">
        <span>Start when computer starts</span>
        <input type="checkbox" />
    </div>


    <MetadataControl Data="@([new DataLayer.Entities.Setting() { Name = DefaultPermissions.ApplicationBackground.ToString(), Value = Background.ToString() }])" TModel="DataLayer.Entities.Setting" Model="[ThemeLayout?.ElementAt(0)]" ValueChanged="@(EventCallback.Factory.Create<Tuple<PropertyMetadata, DataLayer.Entities.Setting, object?>>(this, HandleTheme))" />
    <MetadataControl Data="@([new DataLayer.Entities.Setting() { Name = DefaultPermissions.ApplicationTheme.ToString(), Value = Application.ToString() }])" TModel="DataLayer.Entities.Setting" Model="[ThemeLayout?.ElementAt(1)]" ValueChanged="@(EventCallback.Factory.Create<Tuple<PropertyMetadata, DataLayer.Entities.Setting, object?>>(this, HandleTheme))" />
    <MetadataControl Data="@([new DataLayer.Entities.Setting() { Name = DefaultPermissions.ApplicationSidebar.ToString(), Value = Sidebar.ToString() }])" TModel="DataLayer.Entities.Setting" Model="[ThemeLayout?.ElementAt(2)]" ValueChanged="@(EventCallback.Factory.Create<Tuple<PropertyMetadata, DataLayer.Entities.Setting, object?>>(this, HandleTheme))" />

    <button name="themeSelect" class="cta" @onclick="() => RandomizeTheme()">Randomize Theme</button>

    <h2>Parental Controls</h2>
    <div class="form-row">
        <span>Allow child accounts to subscribe to new content</span>
        <input type="checkbox" />
    </div>


    <h2>Telemetry</h2>
    <div class="form-row">
        <span>Enable non-specific usage statistics sharing with content creators</span>
        <input type="checkbox" />
    </div>
    <div class="form-row">
        <span>Enable non-specific usage statistics sharing with hosts</span>
        <input type="checkbox" />
    </div>

    <h2><a href="@(NavigationExtensions.GetUri<Pages.Admin.Hosting>())">Hosting</a></h2>
    <div>
        <span><a href="@(NavigationExtensions.GetUri<Pages.Admin.Hosting>())">Enable hosting</a> to access your own study system from the web.</span>
    </div>
</div>


<div class="flash-card @GetDisplayClass(DataLayer.ControlMode.List)">
    <div class="settings-page">
        @foreach (var label in themeLabels)
        {
            <label>@label</label>
        }

        @foreach (var theme in extractedThemes ?? [])
        {
            <span class="sticky-left">@theme.ClassName?.Replace("theme-", "")</span>
            @foreach(var variableKey in ThemeVariableKeys)
            {
                <span><span class="sensor" style="@(GetStyle(theme, variableKey))"></span>@theme.Variables.GetValueOrDefault(variableKey)</span>
            }
            <span></span>
        }
    </div>

    <button class="cta" @onclick="() => CopyToCSV()">Copy to CSV</button>
</div>

@code
{
    public DataLayer.ControlMode? Mode { get; set; } = DataLayer.ControlMode.Edit;
    public DataLayer.ControlMode? PreviousMode { get; set; }
    public static List<Retheme.ThemeData>? extractedThemes { get; set;  } 

    private async Task CopyToCSV()
    {
        var csvBuilder = new System.Text.StringBuilder();

        // 1. Add Headers
        csvBuilder.AppendLine(string.Join("\t", themeLabels));

        // 2. Add Rows
        foreach (var theme in extractedThemes ?? [])
        {
            // Note: If data contains commas, you'd wrap values in quotes: "{item.Name}"
            csvBuilder.AppendLine("\"" + string.Join("\"\t\"", ((IEnumerable<string?>)[theme.ClassName]).Concat(ThemeVariableKeys.Select(k => theme.Variables.GetValueOrDefault(k)))) + "\"");
        }

        // 3. Send to Clipboard via JS Interop
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", csvBuilder.ToString());
    }


    public string GetStyle(Retheme.ThemeData theme, string key)
    {
        return "background-color: " + theme.Variables.GetValueOrDefault(key);
    }

    public static readonly List<string> themeLabels = new List<string>
    {
        "Theme Name",
        "Background",
        "Surface",
        "Card",
        "Border",
        "Emerald",
        "Bolt",
        "Amber",
        "Compliment",
        "Text",
        "Muted",
        "Sidebar",
        "Stone",
        "Nature",
        "Electric",
        "Gold",
        "Actions"
    };

    // TODO: move this to ThemeService
    public static readonly List<string> ThemeVariableKeys = new()
    {
        "--slate-bg",
        "--slate-surface",
        "--slate-card",
        "--slate-border",
        "--emerald-glow",
        "--cyan-bolt",
        "--amber-locus",
        "--amber-compliment",
        "--text-main",
        "--text-muted",
        "--text-sidebar",
        "--atrium-stone",
        "--atrium-nature",
        "--atrium-electric",
        "--atrium-gold"
    };

    protected static string? themeContent;

    protected async Task InitializeTheme()
    {
        themeContent = await FileManager.OpenFile("_content/FlashCard/css/theme.css");
        extractedThemes = Retheme.Theme.ExtractThemes(themeContent ?? "");
        StateHasChanged();
    }


    protected void SetControlMode()
    {
        var relativePath = Nav.ToBaseRelativePath(Nav.Uri);

        var segments = relativePath.Split('/');

        DataLayer.ControlMode? newStep = DataLayer.ControlMode.Edit;
        if (segments.Count() >= 2)
        {
            newStep = segments.Last().TryParse<DataLayer.ControlMode>() ?? DataLayer.ControlMode.Edit;
        }


        if (newStep != Mode)
        {
            PreviousMode = Mode;
            Mode = newStep;
            StateHasChanged();
        }

        if(Mode == DataLayer.ControlMode.List)
        {
            TitleService?.UpdateTitle("Edit Theme");
        }
        else if (Mode == DataLayer.ControlMode.Edit)
        {
            TitleService?.UpdateTitle("Application Settings");
        }

    }
    
    protected string? GetDisplayClass(DataLayer.ControlMode mode)
    {
        if (Mode == mode) return "animate-in";
        if (PreviousMode == mode) return "animate-out";
        return "hidden";
    }

    public ApplicationTheme? _app;
    [Display(GroupName = "Themes", Order = 1)]
    public ApplicationTheme? Application
    {
        get
        {
            return _app;
        }
        set
        {
            _app = value;
            ThemeService.SetApplication(_app);
        }
    }

    public SidebarTheme? _theme;
    [Display(GroupName = "Themes", Order = 2)]
    public SidebarTheme? Sidebar
    {
        get
        {
            return _theme;
        }
        set
        {
            _theme = value;
            ThemeService.SetSidebar(_theme);
        }
    }

    IEnumerable<PropertyMetadata>? ThemeLayout { get; set; }


    public AnimationMode? _background;
    [Display(GroupName = "Themes", Order = 0)]
    public AnimationMode? Background
    {
        get
        {
            return _background;
        }
        set
        {
            _background = value;
            ThemeService.SetBackground(_background);
        }
    }


    protected void RandomizeTheme()
    {
        var animationValues = Enum.GetValues<AnimationMode>();
        int randomAnimation = Random.Shared.Next(1, animationValues.Length);
        Background = animationValues[randomAnimation];

        var themeValues = Enum.GetValues<ApplicationTheme>();
        int randomTheme = Random.Shared.Next(1, themeValues.Length);
        Application = themeValues[randomTheme];

        // TODO: always make random sidebar and application match?
        var sidebarValues = Enum.GetValues<SidebarTheme>();
        //int randomSidebar = Random.Shared.Next(1, sidebarValues.Length);
        Sidebar = sidebarValues[randomTheme];
    }

    private async Task HandleTheme(Tuple<PropertyMetadata, DataLayer.Entities.Setting, object?> selectedValue)
    {
        var baseType = Nullable.GetUnderlyingType(selectedValue.Item1.PropertyType) ?? selectedValue.Item1.PropertyType;
        if (baseType == typeof(ApplicationTheme))
        {
            Application = selectedValue.Item3 as ApplicationTheme?;
        }
        else if(baseType == typeof(SidebarTheme))
        {
            Sidebar = selectedValue.Item3 as SidebarTheme?;
        }
        else if (baseType == typeof(AnimationMode))
        {
            Background = selectedValue.Item3 as AnimationMode?;
        }
    }

    [CascadingParameter(Name = "IsStaticRender")] public bool IsStaticRender { get; set; }


    protected override void OnInitialized()
    {
        base.OnInitialized();
        ThemeLayout = typeof(Pages.Admin.Settings).Metadata().Groups["Themes"]?.ToList();
        
        if (IsStaticRender) return;
        // we don't have to reinitialize theme just to get it to show up now
        //   because it's stored in static property after the first load

        MenuService?.SetMenu(@<FlashCard.Pages.Shared.Settings />);
        Nav.LocationChanged += OnLocationChanged;
        _ = InitializeTheme();
    }

    protected bool IsClosing = false;

    protected void OnLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        if (IsClosing) return;
        SetControlMode();
    }

    
    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        SetControlMode();
    }
    
    public void Dispose()
    {
        IsClosing = true;
        Nav.LocationChanged -= OnLocationChanged;
    }


}