@using DataLayer.Utilities
@using FlashCard.Services
@using System
@implements IDisposable
@page "/activity"
@inject IMenuService MenuService
@inject IQueryManager QueryManager
@inject IJSRuntime JS

<SyncedTitle Title="Usage Activity"></SyncedTitle>

<div class="flash-card timeline-viewport" 
     @onwheel="HandleZoom" 
     @onwheel:preventDefault="true"
     @onwheel:stopPropagation="true"
     @ref="timelineRef" @onscroll="HandleScroll">
    <span class="instructions">See a list of program interactions on a timeline.</span>
    <div class="now-indicator"></div> @* Fixed line in the middle *@

    @*ondragstart="() => Dragging = true" 
         @ondragstart:preventDefault="true" 
         @ondragstart:stopPropagation="true" 
         @ondragend="() => Dragging = false"*@

    <div 
         @onmousedown="() => Dragging = true" 
         @onmouseup="() => Dragging = false"
         @onmousemove="HandleMove"
         class="timeline-grid track" style="width: @(TotalWidth)px;">
        <div class="y-axis">
            <button @onclick="() => { ViewportOffset = 0; StateHasChanged(); }">Today</button>
            @for (int i = 0; i < 24; i++)
            {
                <div class="hour-label">@($"{i:D2}:00")</div>
            }
            <div>Zoom: @(ZoomLevel)</div>
        </div>

        <div class="content-area">
            @foreach (var day in GetVisibleDays())
            {
                @* Calculate this day's position relative to the center of the screen *@
                var xPos = CalculateXPosition(day);

                <div class="day-column @(day.Date == DateTime.Today ? "today" : "")"
                     style="width: @(PixelsPerDay)px; transform: translateX(@(xPos)px); position: absolute;">

                    <div class="day-header">@day.ToString("MMM dd")</div>

                    <div class="events-layer">
                        @foreach (var ev in GetEventsForDay(day.Date))
                        {
                            <div class="event-pill"
                                 style="top: @(GetYPosition(ev.Created))px;"
                                 @onclick="() => NavigateToEvent(ev)">
                                @ev?.Path
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>


@code {
    // style="top: @GetYOffset(ev.Time); height: @GetDurationHeight(ev.Duration);"

    private ElementReference timelineRef;
    private double ViewportOffset = 0; // The "Scroll" position in pixels
    private bool Dragging = false;

    private double ZoomLevel = 1.0; // 1.0 = 1 day per 200px
    private int TotalWidth => (int)(PixelsPerDay * 7); // 60 days of buffer
    private double PixelsPerDay => ZoomLevel * 150;

    protected override void OnInitialized()
    {
        // Define the contextual menu for THIS page
        MenuService?.SetMenu(@<FlashCard.Pages.Shared.Users />);
    }
    // This is the key: How many pixels away is this date from the "Zero Point"?
    private double CalculateXPosition(DateTime day)
    {
        // 1. Calculate how many days away this is from Today
        double dayDifference = (day.Date - DateTime.Today).TotalDays;

        // 2. Multiply by pixels per day to get raw position
        double rawX = dayDifference * PixelsPerDay;

        // 3. Add the ViewportOffset (which is our scroll position)
        // We also add (TotalWidth / 2) if we want "Today" to start in the middle
        return rawX + ViewportOffset;
    }


    private CancellationTokenSource? _movects;

    protected async Task HandleMove(MouseEventArgs e)
    {
        if (!Dragging) return;

        // 1. Accumulate the movement immediately (The "Snap" feel)
        // We update the local state so the UI feels responsive
        ViewportOffset += e.MovementX;

        // 2. Cancel the previous "Server/State Sync" timer
        _movects?.Cancel();
        _movects = new CancellationTokenSource();
        var token = _movects.Token;

        try
        {
            // 3. The 50ms Wait Window
            await Task.Delay(50, token);

            // 4. If we made it here without being cancelled,
            // finally trigger the heavy lifting (StateHasChanged / Server Sync)
            StateHasChanged();
        
            // If you were syncing to a remote node in Flagstaff:
            // await SaveViewportPosition(ViewportOffset);
        }
        catch (TaskCanceledException)
        {
            // Silently swallowed: Another move happened within 50ms
        }
    }


    
    private void NavigateToEvent(DataLayer.Entities.Visit visit)
    {
        
    }

    private void HandleScroll(EventArgs e)
    {
        // Use JS Interop here to report back the Left scroll position
        // to calculate which dates to "Stream" or "Skip" via LINQ
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
    //    if (firstRender)
    //    {
    //        var dotNetHelper = DotNetObjectReference.Create(this);
    //        await JS.InvokeVoidAsync("initTimeline", dotNetHelper, timelineRef);
    //    }
    }
    
    private void HandleZoom(WheelEventArgs e)
    {
        //if (e.CtrlKey) // Only zoom if Ctrl is held, like Windows apps
        {
            ZoomLevel = Math.Clamp(ZoomLevel + (e.DeltaY < 0 ? 0.1 : -0.1), 0.5, 5.0);
            StateHasChanged();
        }
    }

    private Dictionary<DateTime, IEnumerable<DataLayer.Entities.Visit>> Events = new();
    
    
    private Dictionary<DateTime, CancellationTokenSource?> _loadcts = new();

    protected async Task UpdateEvents(DateTime day)
    {
        if (!Dragging) return;

        // 2. Cancel the previous "Server/State Sync" timer
        if(_loadcts.TryGetValue(day.Date, out var cts))
        {
            cts?.Cancel();
        }
        ;
        var token = (_loadcts[day.Date] = new CancellationTokenSource()).Token;

        try
        {
            // 3. The 50ms Wait Window
            await Task.Delay(50, token);

            // Temporary Wide Query: Get everything from the last 48 hours
            var wideStart = day.Date.ToUniversalTime();
            var wideEnd = day.Date.AddDays(1).ToUniversalTime();

            if (!Events.TryGetValue(day.Date, out var _))
            {
        
                var allRecent = (await QueryManager.Query<DataLayer.Entities.Visit>(v => v.Created >= wideStart && v.Created < wideEnd)).ToList();
                Events[day.Date] = allRecent;
                if (allRecent.Count > 0)
                {
                    if (allRecent.Count != 0) StateHasChanged();
                }
            }
        }
        catch (TaskCanceledException)
        {
            // Silently swallowed: Another move happened within 50ms
        }
    }


    private int delayCount = 0;
    private IEnumerable<DataLayer.Entities.Visit> GetEventsForDay(DateTime day)
    {
        var localDate = day.Date;

        if (Events.TryGetValue(localDate, out var events))
        {
            return events;
        }
        delayCount++;
        _ = UpdateEvents(localDate);
        return [];
    }

    [JSInvokable]
    public void OnViewportScroll(double deltaX)
    {
        ViewportOffset += deltaX;
        StateHasChanged(); // Triggers the LINQ re-calc
    }

    private IEnumerable<DateTime> GetVisibleDays()
    {
        // Determine which day is currently in the center of the view
        // Negative ViewportOffset means we've scrolled into the past
        double daysScrolled = -ViewportOffset / PixelsPerDay;
        DateTime centerDate = DateTime.Today.AddDays(daysScrolled);

        // We "Take" a window of days.
        // e.g., 5 days before the center and 5 days after
        return Enumerable.Range(-5, 11)
            .Select(i => centerDate.Date.AddDays(i));
    }

    private double GetYPosition(DateTime time) => time.Hour * ZoomLevel + (time.Minute / 60.0 * ZoomLevel);

    public void Dispose()
    {
        
    }

}