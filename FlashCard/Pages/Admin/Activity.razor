@using DataLayer.Utilities
@using DataLayer.Utilities.Extensions
@using FlashCard.Services
@using System
@implements IDisposable
@page "/activity"
@inject IMenuService MenuService
@inject IQueryManager QueryManager
@inject IJSRuntime JS

<SyncedTitle Title="Usage Activity"></SyncedTitle>

<div class="flash-card timeline-viewport" 
     @onscroll="HandleScroll"
     @onwheel="HandleZoom" 
     @onwheel:preventDefault="true"
     @onwheel:stopPropagation="true"
     @ref="timelineRef">
    <span class="instructions">See a list of program interactions on a timeline.</span>
    <div class="now-indicator"></div> @* Fixed line in the middle *@

    @*ondragstart="() => Dragging = true" 
         @ondragstart:preventDefault="true" 
         @ondragstart:stopPropagation="true" 
         @ondragend="() => Dragging = false"*@

    <div 
         @onmousedown="() => Dragging = true" 
         @onmouseup="() => Dragging = false"
         @onmousemove="HandleMove"
         class="timeline-grid track" style="width: @(TotalWidth)px;">
        <div class="key">
            <button @onclick="() => { ViewportOffset = 0; StateHasChanged(); }">Today</button>
            <div>Zoom: @(ZoomLevel)</div>
            <div>Line: @(CalculatedHeight)</div>
        </div>
        <div @ref="yAxisRef" class="y-axis">
            @for (int i = 0; i < 24; i++)
            {
                <div class="hour-label">@($"{i:D2}:00")</div>
            }
            <div class="hour-label">Midnight</div>
        </div>

        <div class="content-area">
            @foreach (var day in GetVisibleDays())
            {
                @* Calculate this day's position relative to the center of the screen *@
                <div class="day-column @(day.Date == DateTime.Today ? "today" : "")"
                     style="@(GetColumnStyle(day))">

                    <div class="day-header">@day.ToString("MMM dd")</div>

                    <div class="events-layer">
                        @if (DayBuckets.TryGetValue(day.Date, out var events))
                        {
                            @foreach (var ev in events)
                            {
                                <div data-hour="@(ev.Created.Hour)" class="event-pill"
                                    style="@(GetYPosition(ev.Created.AddMinutes(-OffsetInMinutes)))"
                                    @onclick="() => NavigateToEvent(ev)">@ev?.Path</div>
                            }
                        }
                        else if (PendingDays.Contains(day.Date))
                        {
                            <div class="loader">Loading...</div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>


@code {
    // style="top: @GetYOffset(ev.Time); height: @GetDurationHeight(ev.Duration);"

    private ElementReference yAxisRef;
    private ElementReference timelineRef;
    private double ViewportOffset = 0; // The "Scroll" position in pixels
    private bool Dragging = false;

    private double ZoomLevel = 1.0; // 1.0 = 1 day per 200px
    private int TotalWidth => (int)(PixelsPerDay * 7); // 60 days of buffer
    private double PixelsPerDay => ZoomLevel * 150;

    public string? GetColumnStyle(DateTime day) => 
        $"width: {PixelsPerDay}px; transform: translateX({CalculateXPosition(day.Date)}px); position: absolute;";


    protected override void OnInitialized()
    {
        // Define the contextual menu for THIS page
        MenuService?.SetMenu(@<FlashCard.Pages.Shared.Users />);
        _ = PopulatorLoop();
    }
    // This is the key: How many pixels away is this date from the "Zero Point"?
    private double CalculateXPosition(DateTime day)
    {
        // 1. Calculate how many days away this is from Today
        double dayDifference = (day.Date - DateTime.Today).TotalDays;

        // 2. Multiply by pixels per day to get raw position
        double rawX = dayDifference * PixelsPerDay;

        // 3. Add the ViewportOffset (which is our scroll position)
        // We also add (TotalWidth / 2) if we want "Today" to start in the middle
        return rawX + ViewportOffset;
    }


    private int _width;
    private int _height;
    private DotNetObjectReference<Pages.Admin.Activity>? _objRef;

    [JSInvokable]
    public void OnWindowResize(int width, int height)
    {
        _width = width;
        _height = height;
        DataLayer.Utilities.Extensions.TaskExtensions
            .Debounce(OnWindowResizeDebounced, 200, JS, yAxisRef)
            .Then<int?>(async task => CalculatedHeight = await task ?? CalculatedHeight)
            .Then(task => InvokeAsync(StateHasChanged));
    }

    public static async Task<int?> OnWindowResizeDebounced(IJSRuntime? JS, ElementReference yAxisRef)
    {
        var result = JS?.InvokeAsync<int>("getLineHeightInt", yAxisRef);
        if(result is ValueTask<int> task)
        {
            await task;
            return (result as dynamic).Result;
        }
        return null;
    }


    public void Dispose() => _objRef?.Dispose();



    private Dictionary<DateTime, List<DataLayer.Entities.Visit>> DayBuckets = new();

    protected async Task HandleMove(MouseEventArgs e)
    {
        if (!Dragging) return;

        // 1. Immediate UI Feedback (The "Snap")
        ViewportOffset += e.MovementX;
        _ = DataLayer.Utilities.Extensions.TaskExtensions
            .Debounce(TriggerSerializedLoad, 200);
    }

    private async Task TriggerSerializedLoad()
    {
        var visibleDays = GetVisibleDays().ToList();

        foreach (var day in visibleDays)
        {
            var dateKey = day.Date;

            // Skip if already loaded or currently loading
            if (DayBuckets.ContainsKey(dateKey) || PendingDays.Contains(dateKey))
                continue;

            PendingDays.Add(dateKey);

            // The 100ms stagger you requested
            await Task.Delay(100);

            await LoadDay(dateKey);
            
            // Refresh UI for this specific day column
            StateHasChanged();
        }
    }

    private async Task LoadDay(DateTime day)
    {
        // Define the UTC window for the query
        // Since AZ is UTC-7, we grab a 48-hour window to be safe for "bleeding" events
        var wideStart = day.AddDays(-1).ToUniversalTime();
        var wideEnd = day.AddDays(2).ToUniversalTime();

        var results = await QueryManager.Query<DataLayer.Entities.Visit>(
            v => v.Created >= wideStart && v.Created < wideEnd).ToListAsync();

        // BUCKETIZE: Only keep events that land on THIS local day after offset
        var localEvents = results
            .Where(v => v.Created.AddMinutes(-OffsetInMinutes).Date == day.Date)
            .ToList();

        DayBuckets[day.Date] = localEvents;
    }


    
    private void NavigateToEvent(DataLayer.Entities.Visit visit)
    {
        
    }

    private void HandleScroll(EventArgs e)
    {
        // Use JS Interop here to report back the Left scroll position
        // to calculate which dates to "Stream" or "Skip" via LINQ
    }


    // TODO: resize stuff to get new line height from css media query

    private int OffsetInMinutes = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _ = DataLayer.Utilities.Extensions.TaskExtensions
                .Debounce(OnWindowResizeDebounced, 200, JS, yAxisRef)
                .Then<int?>(async task => CalculatedHeight = await task ?? CalculatedHeight);
            OffsetInMinutes = await JS.InvokeAsync<int>("eval", "new Date().getTimezoneOffset()");
            _objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("listenToResize", _objRef);
            StateHasChanged();
        }
        //    if (firstRender)
    //    {
    //        var dotNetHelper = DotNetObjectReference.Create(this);
    //        await JS.InvokeVoidAsync("initTimeline", dotNetHelper, timelineRef);
    //    }
    }
    
    private void HandleZoom(WheelEventArgs e)
    {
        //if (e.CtrlKey) // Only zoom if Ctrl is held, like Windows apps
        {
            ZoomLevel = Math.Clamp(ZoomLevel + (e.DeltaY < 0 ? 0.1 : -0.1), 0.5, 5.0);
            StateHasChanged();
        }
    }

    private Dictionary<DateTime, IEnumerable<DataLayer.Entities.Visit>> Events = new();
    
    private HashSet<DateTime> PendingDays = new();
    private bool IsLoading = false;

    // 1. Fetch a wide range to reduce server round-trips
    private async Task LoadDataRange(DateTime start, DateTime end)
    {
        if (IsLoading) return;
        IsLoading = true;

        // Fetch once for the whole view
        var utcStart = start.ToUniversalTime().Date;
        var utcEnd = end.ToUniversalTime().Date;
    
        var allEvents = await QueryManager.Query<DataLayer.Entities.Visit>(
            v => v.Created >= utcStart && v.Created < utcEnd).ToListAsync();

        // 2. Localize and Bucketize immediately
        foreach (var ev in allEvents)
        {
            // Adjust to browser local time before bucketing
            var localTime = ev.Created.AddMinutes(-OffsetInMinutes);
            var dateKey = localTime.Date;

            if (!DayBuckets.ContainsKey(dateKey)) DayBuckets[dateKey] = new();
            DayBuckets[dateKey].Add(ev);
        }
    
        IsLoading = false;
        StateHasChanged();
    }

    // 3. Serialized "Staggered" day populator
    private async Task PopulatorLoop()
    {
        var visible = GetVisibleDays().ToList();
    
        foreach (var day in visible)
        {
            if (DayBuckets.ContainsKey(day.Date) || PendingDays.Contains(day.Date))
                continue;

            PendingDays.Add(day.Date);

            // Artificial 100ms stagger as requested
            await Task.Delay(100);
        
            // Trigger specific day load or use the Range method above
            _ = LoadDay(day.Date);
        }
    }


    [JSInvokable]
    public void OnViewportScroll(double deltaX)
    {
        ViewportOffset += deltaX;
        StateHasChanged(); // Triggers the LINQ re-calc
    }

    private IEnumerable<DateTime> GetVisibleDays()
    {
        // Determine which day is currently in the center of the view
        // Negative ViewportOffset means we've scrolled into the past
        double daysScrolled = -ViewportOffset / PixelsPerDay;
        DateTime centerDate = DateTime.Today.AddDays(daysScrolled);

        // We "Take" a window of days.
        // e.g., 5 days before the center and 5 days after
        return Enumerable.Range(-5, 11)
            .Select(i => centerDate.Date.AddDays(i));
    }

    public int CalculatedHeight { get; set; } = 18;

    private string GetYPosition(DateTime time) 
    {
        return $"top: {(24 - time.Hour) * CalculatedHeight * ZoomLevel + (time.Minute / 60.0 * ZoomLevel)}px;";
    }


}