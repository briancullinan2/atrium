@implements IDisposable

@page "/courses"
@page "/courses/add"
@page "/courses/edit"
@page "/courses/list"
@page "/courses/{Id:int}"
@page "/courses/{Id:int}/view"
@page "/courses/{Id:int}/edit"
@page "/courses/{Id:int}/group"
@page "/courses/{Id:int}/owner"

@using FlashCard.Controls
@using FlashCard.Services
@using System.ComponentModel
@inject IMenuService MenuService
@inject ITitleService TitleService
@inject NavigationManager Nav

<SyncedTitle Title="Courses"></SyncedTitle>

<div class="flash-card @GetDisplayClass(DataLayer.Customization.ControlMode.List)">
    <heading class="flex-row">
        <label></label>
        <label>Course Name</label>
        <label>Category</label>
        <label>Card Count</label>
        <label>Last Studied</label>
        <label>Actions</label>
    </heading>
    <MetadataControl TModel="DataLayer.Entities.Course" Model="@RecentLayout" Data="Recent"></MetadataControl>

</div>



@if (CurrentCourse != null)
{

    <div class="course-edit flash-card @GetDisplayClass(DataLayer.Customization.ControlMode.Edit)">
        <div>
            <fieldset>
                <legend>Course Info</legend>
                <MetadataControl TModel="DataLayer.Entities.Course" Model="@InfoLayout" Data="[CurrentCourse]"></MetadataControl>
            </fieldset>
        </div>
        <div>
            <fieldset>
                <legend>Extended Info</legend>
                <MetadataControl TModel="DataLayer.Entities.Course" Model="@ExtendedLayout" Data="[CurrentCourse]"></MetadataControl>
            </fieldset>
        </div>
        <div class="highlighted-link">
            <button class="deemphasize back" @onclick="(() => NavigationExtensions.NavigateTo<Pages.Admin.Groups>(Nav, u => new() { ControlMode = DataLayer.Customization.ControlMode.List }))"><span class="bi bi-chevron-left"></span>Back</button>
            @if(CurrentCourse.CanonicalFingerprint != null)
            {
                <a href="@(NavigationExtensions.GetUri<Pages.Landing.Courses>(c => new () { ControlMode = DataLayer.Customization.ControlMode.Group, Id = CurrentCourse.Id }))">Course Membership</a>
                <a href="@(NavigationExtensions.GetUri<Pages.Landing.Courses>(c => new() { ControlMode = DataLayer.Customization.ControlMode.Owner, Id = CurrentCourse.Id }))">Course Packs</a>
            }
            <button class="cta" @onclick="() => UpdateCourse()">Save</button>
        </div>

    </div>
    
    <div class="course-edit flash-card @GetDisplayClass(DataLayer.Customization.ControlMode.Group)">
    </div>


    <div class="course-edit flash-card @GetDisplayClass(DataLayer.Customization.ControlMode.Owner)">
    </div>
}



@code {
    public static EntityMetadata Metadata => new EntityMetadata(typeof(Pages.Landing.Courses));
    [Category("Recent")]
    public List<DataLayer.Entities.Course> Recent { get; set; } = new();
    public IEnumerable<PropertyMetadata>? RecentLayout { get; set; }
    public DataLayer.Customization.ControlMode? ControlMode { get; set; }
    public DataLayer.Customization.ControlMode? PreviousMode { get; set; }
    public IEnumerable<PropertyMetadata>? InfoLayout { get; set; }
    public IEnumerable<PropertyMetadata>? ExtendedLayout { get; set; }
    [Parameter] public int? Id { get; set; }
    public DataLayer.Entities.Course? CurrentCourse { get; set; }
    
    protected void UpdateCourse()
    {

    }

    protected string? GetDisplayClass(DataLayer.Customization.ControlMode mode)
    {
        if (ControlMode == mode) return "animate-in";
        if (PreviousMode == mode) return "animate-out";
        // TODO: check what happens when switching from new mode to edit mode
        if (mode == DataLayer.Customization.ControlMode.Edit && ControlMode == DataLayer.Customization.ControlMode.Add) return "animate-in";
        if (mode == DataLayer.Customization.ControlMode.Edit && PreviousMode == DataLayer.Customization.ControlMode.Add) return "animate-out";
        return "hidden";
    }

    protected override void OnInitialized()
    {
        // Define the contextual menu for THIS page
        MenuService?.SetMenu(@<FlashCard.Pages.Shared.Packs />);
        RecentLayout = Pages.Landing.Courses.Metadata.Categories["Recent"]?.ToList();
        InfoLayout = DataLayer.EntityMetadata.Group.Groups["Group Info"]?.ToList();
        ExtendedLayout = DataLayer.EntityMetadata.Group.Groups["Extended Info"]?.ToList();
        Nav.LocationChanged += OnLocationChanged;
    }
    
    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
    
    protected void SetControlMode()
    {
        var relativePath = Nav.ToBaseRelativePath(Nav.Uri);

        var segments = relativePath.Split('/');

        DataLayer.Customization.ControlMode? newStep = DataLayer.Customization.ControlMode.List;
        if (segments.Count() == 2 && Id != null)
        {
            newStep = DataLayer.Customization.ControlMode.View;
        }
        else if (segments.Count() >= 2)
        {
            newStep = segments.Last().TryParse<DataLayer.Customization.ControlMode>() ?? DataLayer.Customization.ControlMode.List;
        }


        
        if (newStep == DataLayer.Customization.ControlMode.List)
        {
            TitleService?.UpdateTitle("Courses");
        }
        else if (newStep == DataLayer.Customization.ControlMode.Add)
        {
            if (CurrentCourse == null || CurrentCourse.CanonicalFingerprint != null)
            {
                CurrentCourse = new DataLayer.Entities.Course();
            }
            TitleService?.UpdateTitle("New Course");
        }
        else if (newStep == DataLayer.Customization.ControlMode.Edit)
        {
            TitleService?.UpdateTitle("Edit Course");
            if (Id != null)
            {
                if (CurrentCourse == null || CurrentCourse.Id != Id)
                {
                    //_ = SetCurrentUser();
                }
            }
        }


        if (newStep != ControlMode)
        {
            PreviousMode = ControlMode;
            ControlMode = newStep;
            InvokeAsync(StateHasChanged);
        }

    }


    protected void OnLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        SetControlMode();
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        Recent.Clear();
        foreach (var course in (Type[])([typeof(Pages.Course.Course)]))
        {
            var courses = GetCourses(course);
            Recent.AddRange(courses ?? []);
        }
        SetControlMode();
        StateHasChanged();
    }

    protected static IEnumerable<DataLayer.Entities.Course>? GetCourses(Type? lesson)
    {
        var generator = lesson?.GetMethod("Generate", System.Reflection.BindingFlags.Static | System.Reflection.BindingFlags.Public);
        IEnumerable<DataLayer.Entities.Course>? packs = generator?.Invoke(null, []) as IEnumerable<DataLayer.Entities.Course>;
        return packs;
    }
}