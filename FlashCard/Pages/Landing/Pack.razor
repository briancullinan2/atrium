    protected async Task OnQuizAnswered(Tuple<PropertyMetadata, Card, object?> valueChanged)
    {
        var answer = valueChanged.Item3 as Answer;
        if (answer == null)
        {
            return;
        }
        var response = new Response()
        {
            Answer = answer,
            Value = answer.Content ?? answer.Value ?? "",
            IsCorrect = answer.IsCorrect,
            Card = valueChanged.Item2
        };
        Responses?.Add(response);
        NextStep();
    }

