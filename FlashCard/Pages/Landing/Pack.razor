    protected string? GetDisplayClass(int? step)
    {
        if (QuizStep == step) return "animate-in";
        if (PreviousStep == step) return "animate-out";
        return "hidden";
    }

    protected override void OnParametersSet()
    {
        _ = SetControlMode();
    }

    protected async Task SetControlMode()
    {
        var relativePath = Nav.ToBaseRelativePath(Nav.Uri);

        var firstSegment = relativePath.Split('/')[0];

        Mode = firstSegment.TryParse<PackMode>();

        if (Mode == PackMode.Shuffle)
        {
            // TODO: if user hasn't logged in, shuffle 5 built in study sauce and then ask for sign up like demo sequence

            List<Card> results = [];
            foreach (var up in UserPacks ?? [])
            {
                await up.Update();
                var retention = Responses?.Where(r => r.Card?.PackId == up.PackId).ToList().GetRetention();
                var due = retention?.Where(r => r.Value.IsDue).Select(r => r.Key);
                results.AddRange(up.Pack?.Cards.Where(c => due?.Contains(c.Id) == true) ?? []);
            }
            CurrentQuiz = results.Shuffle().ToList();
            await InvokeAsync(StateHasChanged);
        }
        else if (Id != null)
        {
            // only show one id quiz
            if (UserPacks?.FirstOrDefault(up => up.Pack?.Id == Id)
                ?.Update<UserPack>() is Task<UserPack> task
                && await task is UserPack up)
            {
                var retention = Responses?.Where(r => r.Card?.PackId == up.PackId).ToList().GetRetention();
                var due = retention?.Where(r => r.Value.IsDue).Select(r => r.Key).ToList() ?? [];
                var cards = up.Pack?.Cards.Where(c => due.Contains(c.Id) == true).ToList() ?? [];
                var result = new List<Card>();
                foreach(var card in cards)
                {
                    var updated = await card.Update<Card>();
                    if (updated == null) return;
                    result.Add(updated);
                }
                CurrentQuiz = result;
                await InvokeAsync(StateHasChanged);
            }
            //var answers = (await Query.Query<Answer>()).ToList();
            //Console.WriteLine(answers);
        }

        _ = TitleService.UpdateTitle(CurrentQuiz?.ElementAtOrDefault(QuizStep)?.Pack?.Title);

    }


