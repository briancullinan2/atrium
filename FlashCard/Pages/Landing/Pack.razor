@page "/shuffle"
@page "/pack/{Id:int}"
@page "/quiz/{Id:int}"
@page "/card/{Id:int}"
@page "/demo/{Id:int}"
@inject NavigationManager Nav
@inject IFormFactor Form
@inject ILoginService LoginService
@inject ITitleService TitleService
@inject IMenuService MenuService
@inject IStudyService StudyService
@inject IQueryManager Query
@implements IHasContext

@using FlashData.Extensions

@if (Mode == null)
{
    <NotFoundControl />
    return;
}

@for(var i = 0; i < CurrentQuiz?.Count(); i++)
{
    var card = CurrentQuiz?.ElementAt(i);
    @*@ondragstart="DragStart"
         @ondragstart:preventDefault="true"
         @ondragstart:stopPropagation="true"
         @ondragend="DragStop"*@
    <div class="flash-card @(GetDisplayClass(i * 2))" 
         style="@(QuizStep == i * 2 ? CurrentManualTransform : "") user-select:none;"
         @onmousedown="DragStart"
         @onmouseup="DragStop"
         @onmousemove="HandleMove">
        <MetadataControl ValueChanged="OnQuizAnswered"
            TModel="Card" Model="@CardLayout" Data="[card]"></MetadataControl>
        <div class="highlighted-link">
            @if (QuizStep > 0)
            {
                <button class="deemphasize back" @onclick="() => LastStep()"><span class="bi bi-chevron-left"></span>Back</button>
            }

            @if (card?.ResponseType == CardType.FlashCard)
            {
                <a class="deemphasize" @onclick:preventDefault="true" @onclick:stopPropagation="true" @onclick="() => NextStep()">Tap or Swipe for answer</a>
            }
            else if (CurrentQuiz?.ElementAt(i).ResponseType == CardType.Short)
            {
                <button class="cta preview-tap" @onclick="() => NextStep()">Submit</button>
            }
        </div>
    </div>

    <div class="flash-card @(GetDisplayClass(i * 2 + 1))" style="@(QuizStep == (i * 2 + 1) ? CurrentManualTransform : "") user-select:none;"
         @ondragstart="DragStart"
         @ondragstart:preventDefault="true"
         @ondragstart:stopPropagation="true"
         @ondragend="DragStop"
         @onmousedown="DragStart"
         @onmouseup="DragStop"
         @onmousemove="HandleMove">
        <MetadataControl TModel="Controls.ResultsCardControl.ResultCard" Model="@ResultLayout" Data="[new Controls.ResultsCardControl.ResultCard() { Card = card, Response = Responses?.FirstOrDefault(r => r.Card == card) }]"></MetadataControl>
        <div class="link-list">
            @if (QuizStep > 0)
            {
                <button class="deemphasize back" @onclick="() => LastStep()"><span class="bi bi-chevron-left"></span>Back</button>
            }
            <a class="deemphasize" @onclick:preventDefault="true" @onclick:stopPropagation="true" @onclick="() => NextStep()">Tap or Swipe for next card</a>
        </div>
    </div>
}

@*TODO: show results screen if retention is already resolved*@

@* Progress Tracker *@
@if (TotalCards != null)
{
    <ul class="tab-tracker">
        @for (var i = Math.Max((int)QuizStep - 2, 0); i < Math.Min((int)TotalCards, (int)QuizStep + 3); i++)
        {
            <li class="@(i == QuizStep ? "text-amber-500 text-xl" : "text-slate-300")">
                &bullet;
                <span>@QuizStep</span>
            </li>
        }
    </ul>
    @*Add one for visual, CurrentIndex is zero based*@
    <div class="preview-count">@(QuizStep + 1) of @TotalCards</div>
}


