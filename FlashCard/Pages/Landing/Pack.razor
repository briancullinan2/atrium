    public PackMode? Mode { get; set; }

    private IEnumerable<PropertyMetadata>? CardLayout;
    private IEnumerable<PropertyMetadata>? ResultLayout;
    public int? PreviousStep { get; set; }
    public int QuizStep { get; set; } = 0;
    public int? TotalCards { get => CurrentQuiz?.Count() * 2; }
    private bool Dragging = false;
    private double CumulativeX = 0;
    private double CumulativeY = 0;

    public List<UserPack>? UserPacks { get; set; }
    public List<Response>? Responses { get; set; }


    private string CurrentManualTransform = "";
    protected async Task DragStart(MouseEventArgs e)
    {
        Dragging = true;
        CumulativeX = 0;
        CumulativeY = 0;
    }

    protected async Task DragStop(MouseEventArgs e)
    {
        CurrentManualTransform = "";
        CumulativeX = 0;
        CumulativeY = 0;
        Dragging = false;
        await InvokeAsync(StateHasChanged);
    }

    protected async Task HandleMove(MouseEventArgs e)
    {
        if ((e.Buttons & 1) > 0 && Dragging)
        {
            CumulativeX += e.MovementX;
            CumulativeY += e.MovementY;

            CurrentManualTransform = CalculateTransform(CumulativeX, CumulativeY);
            await InvokeAsync(StateHasChanged);

            // Auto-trigger the full animation if they hit 100%
            double distance = Math.Sqrt(Math.Pow(CumulativeX, 2) + Math.Pow(CumulativeY, 2));

            if (distance >= MaxDistance / 10)
            {
                NextStep();
            }
        }
    }


    protected void LastStep()
    {
        PreviousStep = QuizStep;
        QuizStep--;
        CurrentManualTransform = "";
        CumulativeX = 0;
        CumulativeY = 0;
        Dragging = false;
        InvokeAsync(StateHasChanged);
    }


    protected void NextStep()
    {
        PreviousStep = QuizStep;
        QuizStep++;
        CurrentManualTransform = "";
        CumulativeX = 0;
        CumulativeY = 0;
        Dragging = false;
        InvokeAsync(StateHasChanged);
    }

    private const double MaxDistance = 1000.0; // Your 100% threshold in pixels

    public string CalculateTransform(double currentX, double currentY)
    {
        // 1. Calculate the 'Percent Complete' (0.0 to 1.0)
        double distance = Math.Sqrt(Math.Pow(currentX, 2) + Math.Pow(currentY, 2));
        double t = Math.Clamp(distance / MaxDistance, 0, 1);

        // 2. Quadratic Bézier for X and Y positions
        // Formula: (1-t)^2*P0 + 2(1-t)*t*P1 + t^2*P2
        double x = (2 * (1 - t) * t * 20) + (Math.Pow(t, 2) * 400);
        double y = (2 * (1 - t) * t * -20) + (Math.Pow(t, 2) * -600);

        // 3. Linear Interpolation for Rotation, Scale, and Opacity
        double rotateY = t * 180;        // 0 to 180deg
        double scale = 1.0 - (t * 0.8);  // 1.0 to 0.2
        double opacity = 1.0 - t;        // 1.0 to 0.0

        return $"transform: translate({x:F2}px, {y:F2}px) rotateY({rotateY:F2}deg) scale({scale:F2}) !important; opacity: {opacity:F2};";
    }

    protected override void OnInitialized()
    {
        base.OnInitialized();
        CardLayout = typeof(Pages.Landing.Pack).Metadata().Categories["Display"]?.ToList();
        ResultLayout = typeof(Pages.Landing.Pack).Metadata().Categories["Results"]?.ToList();
        Query.Query<UserPack>(up => up.UserId == LoginService.UserId).ToListAsync()
            .Then(async list => UserPacks = await list);
        Query.Query<Response>(up => up.Created > DateTime.Now.AddDays(-32) && up.UserId == LoginService.UserId).ToListAsync()
        .Then(async list => Responses = await list);
    }


