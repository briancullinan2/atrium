@page "/login"
@page "/login/callback"
@page "/login/callback/{ServiceId}"
@using FlashCard.Services
@using System.Security.Claims
@attribute [AllowAnonymous]
@inject IMenuService MenuService
@inject ILoginService LoginService
@inject IAuthService AuthService
@inject NavigationManager Nav
@inject AuthenticationStateProvider Auth

<SyncedTitle Title="User Login"></SyncedTitle>

<div class="flash-card">
    <h2>Who is using the app?</h2>
    <div class="user-list">
        @foreach(var user in Users ?? [])
        {
            <div class="user-avatar">
                <a @onclick="() => HandleLogin(user)">
                    @if (user.PhotoHosted != null || user.Photo?.Url != null)
                    {
                        <img src="@(user.PhotoHosted ?? user.Photo?.Url)" />
                    } else
                    {
                        <span style="@GetBackgroundColor(user)" class="bi bi-person-circle"></span>
                    }
                    <span>@user.FirstName @user.LastName</span>
                    <span>@user.Username</span>
                </a>
                <span><a href=""><span class="bi bi-pencil"></span></a></span>
            </div>
        }
    </div>
</div>


@code {
    [Parameter] public string? ServiceId { get; set; }
    public IEnumerable<DataLayer.Entities.User>? Users { get; set; }

    public string GetBackgroundColor(DataLayer.Entities.User user)
    {
        if (Users == null) return "blue";
        var index = Users.ToList().IndexOf(user);
        var (r, g, b) = Utilities.RgbToHslTools.HslToRgb((360 / (Users.Count() + 1)) * index, 0.5, 0.5);
        return $"background-color:#{(int)r:X2}{(int)g:X2}{(int)b:X2};";
    }

    protected async Task HandleLogin(DataLayer.Entities.User user)
    {
        // 1. Create the Claims for this user
        var claims = new List<Claim>
        {
            new Claim(ClaimTypes.Name, user.Username ?? ""),
            new Claim(ClaimTypes.GivenName, user.FirstName ?? ""),
            new Claim(ClaimTypes.Surname, user.LastName ?? ""),
            new Claim("UserId", user.Guid?.ToString() ?? ""),
            // Add roles based on your DefaultRoles enum
            new Claim(ClaimTypes.Role, "User")
        };

        var identity = new ClaimsIdentity(claims, "AtriumAuth");
        var principal = new ClaimsPrincipal(identity);

        // 2. Call the provider to save to DB and set the Cookie
        if (Auth is DatabaseStateProvider dbAuthProvider)
        {
            await dbAuthProvider.MarkUserAsAuthenticated(principal);
        }

        // 3. UI logic
        _ = LoginService.SetUser(user);
        _ = LoginService.SetLoginMode(false);
    
        Nav.NavigateTo("/"); // Use your NavigationExtensions or standard Nav
    }


    [CascadingParameter(Name = "IsStaticRender")] public bool IsStaticRender { get; set; }

    protected override void OnInitialized()
    {
        if (IsStaticRender) return;
        // Equivalent to: Source={x:Static data:EntityMetadata.User.Categories[Login Info]}
        // We assign the specific "Login Info" object to the Model property
        //CurrentCategory = EntityMetadata.User.Groups["Login Info"]?.ToList();
        MenuService.SetMenu(null);
        MenuService.SetHeader(false);
        LoginService.SetLoginMode(true);
        LoginService.SetUser(null);
    }


    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        Users = DataLayer.Generators.Users.Generate();
        StateHasChanged();
    }
}
