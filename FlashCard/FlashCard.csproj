<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
	  <TargetFrameworks>net10.0</TargetFrameworks>
	  <Nullable>enable</Nullable>
	  <ImplicitUsings>disable</ImplicitUsings>
	  <WasmFingerprintAssets>false</WasmFingerprintAssets>
	  <ApplicationTitle>Atrium</ApplicationTitle>
	  <ApplicationId>com.atrium.desktop</ApplicationId>
	  <Authors>Brian Cullinan</Authors>
	  <Product>Atrium</Product>
	  <Company>Brian Cullinan</Company>
  </PropertyGroup>
	
	<PropertyGroup>
		<RuntimeIdentifiers>android-arm64;android-x64</RuntimeIdentifiers>
	</PropertyGroup>
	
	<PropertyGroup>
		<NoWarn>$(NoWarn);BL0005</NoWarn>
	</PropertyGroup>
	

	
	
  <ItemGroup>
    <ProjectReference Include="..\DataStore\DataStore.csproj" />
    <ProjectReference Include="..\Extensions\Extensions.csproj" />
    <ProjectReference Include="..\RazorSharp\RazorSharp.csproj" />
    <ProjectReference Include="..\FlashData\FlashData.csproj" />
  </ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.AspNetCore.Components.Authorization" Version="10.0.*-*" />
		<PackageReference Include="Microsoft.AspNetCore.Components.Web" Version="10.0.*-*" />
	</ItemGroup>
	
  <ItemGroup>
    <Content Update="wwwroot\triangle.svg">
      <Color>transparent</Color>
    </Content>
  </ItemGroup>

</Project>