    private IJSObjectReference? _animationCts;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!initRender || Background == null)
        {
            return;
        }
        initRender = false;

        if(_animationCts != null)
        {
            _ = _animationCts.InvokeVoidAsync("dispose");
            _ = _animationCts.DisposeAsync();
            _animationCts = null;
        }

        if(Background == AnimationMode.None)
        {
            return;
        }

        // Trigger the JS engine
        //await JS.InvokeVoidAsync("initLichtenberg", "lichtenbergCanvas");
        var _module = await JS.InvokeAsync<IJSObjectReference>("import", $"/_content/FlashCard/{Background.ToString()?.ToLowerInvariant()}.js");

        // 2. Call the function from the module
        _animationCts = await _module.InvokeAsync<IJSObjectReference>("initLichtenberg", "lichtenbergCanvas");

    }

    public async ValueTask DisposeAsync()
    {
        if (_animationCts != null)
        {
            _ = _animationCts.InvokeVoidAsync("dispose");
            _ = _animationCts.DisposeAsync();
            _animationCts = null;
        }
    }
}