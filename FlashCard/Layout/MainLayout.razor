@using DataLayer.Utilities.Extensions
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.HtmlRendering
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.Extensions.Logging
@using Microsoft.Extensions.Options
@using FlashCard.Services
@using FlashCard.Controls
@inherits LayoutComponentBase
@implements IDisposable
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject IMenuService MenuService
@inject IThemeService ThemeService
@inject IStudyService StudyService
@inject ILoginService LoginService
@inject ITitleService TitleService
@inject IServiceProvider ServiceProvider
@inject IJsonService JsonService
@inject ILoggerFactory LoggerFactory
@inject IChatService ChatService
@inject NavigationManager Nav

<div class="@(Login == true ? "login-mode" : Study == true ? "study-mode" : "") @(ShowChat == true ? "chatting" : "") @PageClass page theme-@(Application.ToString()?.ToLowerInvariant())">
    <div id="theme-sensor" style="display:none;">
        <span class="sensor-bg"></span>
        <span class="sensor-surface"></span>
        <span class="sensor-primary"></span>
        <span class="sensor-secondary"></span>
        <span class="sensor-accent"></span>
        <span class="sensor-main"></span>
        <span class="sensor-stone"></span>
        <span class="sensor-nature"></span>
        <span class="sensor-electric"></span>
        <span class="sensor-gold"></span>
    </div>

    <div class="canvas-container">
        <canvas id="lichtenbergCanvas"></canvas>
    </div>
    <div class="sidebar theme-@(Sidebar.ToString()?.ToLowerInvariant())">
        <NavMenu />
    </div>
    
    @foreach (var item in State)
    {
        <input type="hidden" name="state_@item.Key" value="@item.Value" />
    }

    @if (ShowHeader != false)
    {
        <header class="top-row px-4">
            @if (HeaderTitle != null)
            {
                <h2>@HeaderTitle</h2>            
            }
            @if (HeaderMenu != null)
            {
                <div class="contextual-menu">
                    @HeaderMenu
                </div>
            }
            @if (HeaderMenu == null && HeaderTitle == null)
            {
                <span>&nbsp;</span>
            }
        </header>
    }
    <main>

        <article class="content course-container">
            @if(_previousBody != null)
            {
                <div class="flash-card @(_isTransitioning ? "animate-out" : "")">
                    @(_previousBody)
                </div>
            }
            @_activeBody
        </article>

    </main>

    @if (ShowChat == true)
    {
        <div class="chat-box">
            <input @onkeydown="HandleKeyDown" @bind:event="oninput" @bind="ChatMessage" type="text" placeholder="Type your message here..." /><button class="cta" @onclick="() => SendMessage()">Send</button>
        </div>
    }
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    public RenderFragment? HeaderMenu { get; private set; }
    public string? HeaderTitle { get; private set; }
    //public object? Tag { get; set; } // for comparing states for implementers
    public bool? Login { get; set; }
    public DataLayer.Entities.User? CurrentUser { get; set; }
    public bool? Study { get; set; }
    public string? PageClass { get; set; }
    public bool? ShowHeader { get; set; }
    public bool? ShowChat { get; set; }
    public string? ChatMessage { get; set; }

