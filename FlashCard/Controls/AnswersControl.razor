@using System.ComponentModel.DataAnnotations
@using System.ComponentModel
@using DataLayer.Utilities.Extensions
@code
{
    [Parameter] public IEnumerable<Card>? Data { get; set; }
    [Parameter] public PropertyMetadata? Model { get; set; }
    [Parameter] public EventCallback<object?>? ValueChanged { get; set; }
    public List<Answer> Answers { get; set; } = new List<Answer>();


    public DataLayer.ControlMode Mode
    {
        get
        {
            // TODO: declaring type
            return DataLayer.ControlMode.View;
        }
    }

    protected override void OnInitialized()
    {
        Answers = Data?.ElementAt(0).Answers.ToList() ?? [];
        if(Data?.ElementAt(0).ResponseType == DataLayer.CardType.TrueFalse)
        {
            if (!Answers.Any(a => string.Equals(a.Value, "true", StringComparison.InvariantCultureIgnoreCase)))
            {
                Answers.Add(new Answer()
                {
                    Value = "True",
                    Content = "True"
                });
            }
            if (!Answers.Any(a => string.Equals(a.Value, "false", StringComparison.InvariantCultureIgnoreCase)))
            {
                Answers.Add(new Answer()
                {
                    Value = "False",
                    Content = "False"
                });
            }
        }
    }

}




@foreach (var answer in Answers)
{
    <input class="large-present" type="radio" value="@answer.Value ?? answer.Content" id="@answer.Content?.ToSafe()" name="@Data?.ElementAt(0).Content.ToSafe()" />
    <label for="@answer.Content?.ToSafe()" onclick="@(() => ValueChanged?.InvokeAsync(answer))">@answer.Content</label>
}
