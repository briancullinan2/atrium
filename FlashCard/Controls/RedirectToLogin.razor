@using FlashCard.Services
@using Microsoft.AspNetCore.Http;
@using Microsoft.Extensions.DependencyInjection
@inject NavigationManager Navigation
@inject IServiceProvider Services
@inject IPageManager PageManager

@code {
    [CascadingParameter(Name = "IsStaticRender")] public bool IsStaticRender { get; set; }

    protected override void OnInitialized()
    {
        if (IsStaticRender) return;

        var httpContext = Services.GetService<IHttpContextAccessor>();
        var contextKey = "Internal";
        // so web clients don't interfere with desktop clients
        if (httpContext != null && httpContext.HttpContext != null)
        {
            contextKey = httpContext.HttpContext.Connection.RemoteIpAddress.ToString();
        }
        // try not to double stack redirects if controls are doing something
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (PageManager.InFlight.TryGetValue(contextKey, out var _)) return;
        PageManager.InFlight.TryAdd(contextKey, uri.PathAndQuery);
        Navigation.NavigateTo<Pages.Landing.Login>(l => new()
        {
            ReturnUrl = uri.PathAndQuery
        });
    }
}