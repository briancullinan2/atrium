@attribute [SupportsType(typeof(Pack))]
@attribute [SupportsType(typeof(IEnumerable<Pack>))]
@implements IHasMeta
@inject ILoginService LoginService
@inject IQueryManager QueryManager

@code
{

    [Parameter] public IEnumerable<object?>? Data { get; set; }
    [Parameter] public PropertyMetadata? Model { get; set; }
    [Parameter] public EventCallback<object?>? ValueChanged { get; set; }

    public IEnumerable<Pack> Packs { get => Data?.Cast<Pack>() ?? []; }
    public List<UserPack> UserPacks { get => LoginService?.User?.UserPacks ?? []; }
}


@foreach (var pack in Packs)
{
    <div class="flex-row">
        <span><img src="@(pack.LogoHosted ?? pack.Logo?.Url)" /></span>
        <span>
            @if (LoginService?.User?.UserPacks.FirstOrDefault(up => up.PackId == pack.Id) != null)
            {
                <a href="@(TypeExtensions.GetUri<Pages.Landing.Pack>(p => new() { Id = pack.Id, Mode = PackMode.Card }))">@pack.Title</a>
            }
            else
            {
                <a href="@(TypeExtensions.GetUri<Pages.Landing.Pack>(p => new() { Id = pack.Id, Mode = PackMode.Demo }))">@pack.Title</a>
            }
        </span>
        <span>@pack.Category
            @if(!string.IsNullOrWhiteSpace(pack.Tags))
            {
                <span>(@pack.Tags)</span>
            }
        </span>
        <span>@pack.Cards.Count()</span>
        <span>@(LoginService?.User?.UserPacks.FirstOrDefault(up => up.PackId == pack.Id)?.GetResponses(out var correct)?.LastOrDefault()?.Created.ToString("MMM dd") ?? "Never studied")</span>
        <span>
            <a href="@(TypeExtensions.GetUri<Pages.Landing.EditPack>(p => new () { Mode = ControlMode.Edit, Id = pack.Id}))">
                <span class="bi bi-pencil"></span>
            </a>
            @if(LoginService?.User == null)
            {
                <a href="@(TypeExtensions.GetUri<Pages.Landing.Login>())">
                    <span class="bi bi-check-circle"></span>
                </a>
            }
            else if (LoginService?.User?.UserPacks.FirstOrDefault(up => up.PackId == pack.Id) == null)
            {
                <a href="@(TypeExtensions.GetUri<Pages.Landing.Packs>(p => new() { Mode = ControlMode.Add, Id = pack.Id }))">
                    <span class="bi bi-check-circle"></span>
                </a>
            } else
            {
                <a href="@(TypeExtensions.GetUri<Pages.Landing.Pack>(p => new() { Mode = PackMode.Card, Id = pack.Id }))">
                    <span class="bi bi-info-circle"></span>
                </a>
            }
        </span>
    </div>
}
