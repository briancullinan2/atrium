@using System.ComponentModel.DataAnnotations
@using System.ComponentModel
@using System.Text.Json.Serialization
@using FlashCard.Services
@inject IFileManager FileManager
@inject IAnkiService AnkiService

@code
{

    [Parameter] public IEnumerable<DataLayer.Entities.File>? Data { get; set; }
    [Parameter] public PropertyMetadata? Model { get; set; }
    [Parameter] public EventCallback<object> ValueChanged { get; set; }


    protected override void OnInitialized()
    {

    }

    public async Task Delete(DataLayer.Entities.File file)
    {

    }

    public async Task Download(DataLayer.Entities.File file)
    {
        var ankiResults = await AnkiService.Download(file.Url);
        await ValueChanged.InvokeAsync(ankiResults);
    }

    public async Task Import(DataLayer.Entities.File file)
    {
        var ankiResults = await AnkiService.InspectFile(file.Filename);
        await ValueChanged.InvokeAsync(ankiResults);
    }

}



@for (var i = 0; i < Data?.Count(); i++)
{
    var file = Data.ElementAt(i);
    if (file == null) continue;
    <div class="flex-row ">
        <span>@(i + 1)</span>
        <span>@Path.GetFileName(file.Filename)</span>
        <span>@file.Url</span>
        <span>@file.Source</span>
        <span>
            @if (Model?.DeclaringType == typeof(Pages.Content.Upload))
            {
                @if(file.Url != null && file.Filename == null)
                {
                    <a @onclick="() => { _ = Download(file!); }"><span class="bi bi-download"></span></a>
                }
                else
                {
                    <a @onclick="() => { _ = Import(file!); }"><span class="bi bi-pencil"></span></a>
                    <a @onclick="() => { _ = Delete(file!); }"><span class="bi bi-trash"></span></a>
                }
            }
        </span>
    </div>
}
