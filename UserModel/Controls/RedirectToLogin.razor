@using FlashCard.Services
@using Microsoft.AspNetCore.Http;
@using Microsoft.Extensions.DependencyInjection
@inject NavigationManager Navigation
@inject IServiceProvider Services
@inject IPageManager PageManager

@code {
    [CascadingParameter(Name = "IsStaticRender")] public bool IsStaticRender { get; set; }

    protected override void OnInitialized()
    {
        if (IsStaticRender) return;


        // try not to double stack redirects if controls are doing something
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        string? existing;
        PageManager.InFlight.TryGetValue(PageManager.ContextKey, out existing);
        var newPage = PageManager.InFlight[PageManager.ContextKey] = NavigationExtensions.GetUri<Pages.Landing.Login>(l => new()
        {
            ReturnUrl = uri.PathAndQuery
        });
        if(existing?.Contains("login") == true)
        {
            return;
        }
        else
        {
            Navigation.NavigateTo(newPage, true);
        }
    }
}