<Project Sdk="Microsoft.NET.Sdk.Razor">

	<PropertyGroup>
		<TargetFrameworks>net10.0</TargetFrameworks>
		<ImplicitUsings>disable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<ApplicationTitle>Atrium</ApplicationTitle>
		<ApplicationId>com.atrium.desktop</ApplicationId>
		<Authors>Brian Cullinan</Authors>
		<Product>Atrium</Product>
		<Company>Atrium</Company>
		<Publisher>Brian Cullinan</Publisher>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="AspNet.Security.OAuth.Apple" Version="10.0.*-*" />
		<PackageReference Include="AspNet.Security.OAuth.Discord" Version="10.0.*-*" />
		<PackageReference Include="AspNet.Security.OAuth.GitHub" Version="10.0.*-*" />
		<PackageReference Include="Microsoft.AspNetCore.Authentication.Facebook" Version="10.0.*-*" />
		<PackageReference Include="Microsoft.AspNetCore.Authentication.Google" Version="10.0.*-*" />
		<PackageReference Include="Microsoft.AspNetCore.Authentication.MicrosoftAccount" Version="10.0.*-*" />
		<PackageReference Include="Microsoft.AspNetCore.Authentication.OpenIdConnect" Version="10.0.*-*" />
		<PackageReference Include="Microsoft.AspNetCore.Authentication.Twitter" Version="10.0.*-*" />
		<PackageReference Include="Microsoft.AspNetCore.Components.Authorization" Version="10.0.*-*" />
	</ItemGroup>

	<ItemGroup>
	  <ProjectReference Include="..\DataStore\DataStore.csproj" />
	  <ProjectReference Include="..\Interfacing\Interfacing.csproj" />
	  <ProjectReference Include="..\RazorSharp\RazorSharp.csproj" />
	  <ProjectReference Include="..\UserData\UserData.csproj" />
	</ItemGroup>

	<PropertyGroup>
		<SignAssembly>true</SignAssembly>
		<AssemblyOriginatorKeyPassword>YourSecurePassword</AssemblyOriginatorKeyPassword>
		<AssemblyOriginatorKeyFile>$(UserProfile)\.credentials\my-code-signing-legacy.pfx</AssemblyOriginatorKeyFile>
	</PropertyGroup>

	<Target Name="CopyPluginToHost" AfterTargets="PostBuildEvent" Condition="'$(TargetFramework)' == 'net10.0-windows10.0.19041.0'">
		<PropertyGroup>
			<HostBinPath>$(SolutionDir)Atrium\bin\$(Configuration)\$(TargetFramework)\win-x64\</HostBinPath>

			<HostingContentPath>$(HostBinPath)wwwroot\_content\Hosting\</HostingContentPath>
		</PropertyGroup>

		<ItemGroup>
			<PluginBinaries Include="$(TargetDir)**\*.*" Exclude="$(TargetDir)wwwroot\**\*.*" />

			<PluginRootAssets Include="$(TargetDir)wwwroot\*.*" />

			<HostingProjectAssets Include="$(TargetDir)Hosting\wwwroot\**\*.*" />
		</ItemGroup>

		<Copy SourceFiles="@(PluginBinaries)"
			  DestinationFolder="$(HostBinPath)%(RecursiveDir)"
			  SkipUnchangedFiles="true" />

		<Copy SourceFiles="@(PluginRootAssets)"
			  DestinationFolder="$(HostBinPath)wwwroot\"
			  SkipUnchangedFiles="true" />

		<Copy SourceFiles="@(HostingProjectAssets)"
			  DestinationFiles="@(HostingProjectAssets->'$(HostingContentPath)%(RecursiveDir)%(Filename)%(Extension)')"
			  SkipUnchangedFiles="true" />
	</Target>
</Project>
