@page "/hosting"
@implements IDisposable
@implements IHasForms
@inject IServiceProvider ServiceProvider

@attribute [Display(Name = "Hosting", GroupName = "Administration", Prompt = "bi-hdd-network")]


<div class="form-row">
    <label>Enable HTTP hosting</label>
    <input type="checkbox" />
</div>

<AccordionSection IsExpanded="IsWorking != true" Title="Become A Host">
    <p>The easiest pipeline to monitored hosting is to enable the Atrium web service.</p>
    <p>Then use cloud-flared reverse tunnel to secure your domain past any firewall restrictions.</p>
    <p>Disclaimer - This requires administrator privileges, so probably don't try it at work.</p>
</AccordionSection>

<AccordionSection IsExpanded="IsWorking != true" Title="Install Prerequisites">
    <a href="https://github.com/cloudflare/cloudflared/releases">Cloud Flared download page</a>
    <h3>Create a tunnel</h3>
    <a href="https://developers.cloudflare.com/cloudflare-one/networks/connectors/cloudflare-tunnel/get-started/create-remote-tunnel/">Set up a tunnel</a>
    <h3>Create a read all token</h3>
    <a href="https://developers.cloudflare.com/fundamentals/api/get-started/create-token/">Create token instructions</a>
    <h3>Install Atrium service</h3>
    @if (!OperatingSystem.IsWindows())
    {
        <p>Click here to run Atrium service install</p>
    }
    else
    {
        <p>Run Atrium desktop to use your own hosted service</p>
    }
</AccordionSection>

<AccordionSection IsExpanded="IsWorking != true" Title="Account Settings">
    <label>Tunnel Name</label>
    <input @bind="TunnelName" type="text" />

    <label>API Token</label>
    <input @bind="ApiToken" type="password" />

    <label>Account ID</label>
    <input @bind="AccountId" type="text" />

    <label>Domain Name</label>
    <input @bind="Domain" type="text" />
</AccordionSection>

<heading class="flex-row">
    <label></label>
    <label>Service</label>
    <label>Status</label>
    <label>Last Checked</label>
    <label>Actions</label>
</heading>
    
<div class="flex-row">
    <span></span>
    <span>Cloud Flare Service</span>
    <span>@serviceStatus</span>
    <span>@serviceChecked</span>
    <span><span class="bi @(IsServicing == true ? "bi-check-circle" : IsServicing == false ? "bi-x-circle" : "bi-clock")"></span></span>
</div>
<div class="flex-row">
    <span></span>
    <span>Cloud Flare Api</span>
    <span>@tunnelStatus</span>
    <span>@lastChecked</span>
    <span><span class="bi @(IsTunneling == true ? "bi-check-circle" : IsTunneling == false ? "bi-x-circle" : "bi-clock")"></span></span>
</div>
<div class="flex-row">
    <span></span>
    <span>Atrium</span>
    <span>@hostStatus
        @if(IsWorking == true)
        {
            <span> site is <a href="https://@(Domain)/">live and accessible.</a></span>
        }
    </span>
    <span>@hostChecked</span>
    <span><span class="bi @(IsWorking == true ? "bi-check-circle" : IsWorking == false ? "bi-x-circle" : "bi-clock")"></span></span>
</div>



@code
{

    protected static IServiceProvider? Services { get; set; }

    protected override void OnInitialized()
    {
        Instance = this;
        Services = ServiceProvider;
        _ = TaskExtensions.Debounce(PollTunnelStatusAsync, 60 * 3 * 1000);
        _timer = TaskExtensions.Timer(PollTunnelStatusAsync, 60 * 3 * 1000);
    }

    private static string? _apiToken;
    private static string? ApiToken
    {
        get => _apiToken;
        set
        {
            _apiToken = value;
            _ = TaskExtensions.Debounce(PollTunnelStatusAsync, 60 * 3 * 1000);
        }
    }
    private static string? _tunnelName;
    private static string? TunnelName
    {
        get => _tunnelName;
        set
        {
            _tunnelName = value;
            _ = TaskExtensions.Debounce(PollTunnelStatusAsync, 60 * 3 * 1000);
        }
    }
    private static string? _accountId;
    private static string? AccountId
    {
        get => _accountId;
        set
        {
            _accountId = value;
            _ = TaskExtensions.Debounce(PollTunnelStatusAsync, 60 * 3 * 1000);
        }
    }
    private static string? _domain;
    private static string? Domain
    {
        get => _domain;
        set
        {
            _domain = value;
            _ = TaskExtensions.Debounce(PollTunnelStatusAsync, 60 * 3 * 1000);
        }
    }

    private static string? tunnelStatus = "Checking Cloud Flare...";
    private static string lastChecked = "Never";
    private static string? hostStatus = "Checking Public Access...";
    private static string hostChecked = "Never";
    private static string? serviceStatus = "Checking Services...";
    private static string serviceChecked = "Never";
    private static CancellationTokenSource? _timer;
    private static bool? IsWorking { get; set; } = null;
    private static bool? IsTunneling { get; set; } = null;
    private static bool? IsServicing { get; set; } = null;
    protected static global::Hosting.Pages.Hosting? Instance { get; set; }

    private static async Task PollTunnelStatusAsync()
    {
        await CheckStatus();
        if (Instance != null) await Instance.InvokeAsync(ChangeState);
    }

    protected static void ChangeState() => Instance?.InvokeAsync(Instance.StateHasChanged);


    public void Dispose()
    {
        _timer?.Cancel();
        //_timer?.Dispose();
        _timer = null;
    }


    private static async Task CheckStatus()
    {
        try
        {
            var StatusService = Services?.GetService(typeof(IHostingService)) as IHostingService;

            if(StatusService == null)
            {
                return;
            }

            var token = await StatusService.GetToken();
            var host = await StatusService.GetHost();


            tunnelStatus = await StatusService.CheckTunnel(AccountId, TunnelName, ApiToken);
            IsTunneling = tunnelStatus == "healthy";
            lastChecked = DateTime.Now.ToLongTimeString();


            IsServicing = await StatusService.CheckInstalled();
            serviceStatus = IsServicing == true ? "Service is installed" : "Service is not installed";
            serviceChecked = DateTime.Now.ToLongTimeString();

            if(string.IsNullOrWhiteSpace(Domain))
            {
                Domain = host;
            }

            if (string.IsNullOrWhiteSpace(Domain))
            {
                hostStatus = "Domain name not set.";
                return;
            }

            var result = await StatusService.CheckStatus(Domain);

            if (StatusResponse.ItWorks?[0] == token)
            {
                hostStatus = $"Tokens match, ";
                IsWorking = true;
            } else
            {
                hostStatus = "Token mismatch, site is not accessible.";
            }
            hostChecked = DateTime.Now.ToLongTimeString();

            // Required to tell Blazor the data changed outside of a UI event
        }
        catch (System.Text.Json.JsonException ex)
        {
            hostStatus = "Response parse error: " + ex.Message;
        }
        catch (Exception ex)
        {
            hostStatus = "Error: " + ex.Message;
        }
    }
}