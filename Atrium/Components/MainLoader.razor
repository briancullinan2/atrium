@using Atrium.Services
@using Interfacing.Services
@using Microsoft.AspNetCore.Components.Rendering
@using Microsoft.AspNetCore.Components.Routing
@inject ITrustProvider Trust
@inject NavigationManager Nav
@inject IServiceProvider Service
@inject ITrustProvider Trust

@if (IsDebug)
{
    <script>
        (function() {
        const originalInvoke = DotNet.invokeMethodAsync;
        DotNet.invokeMethodAsync = function(assemblyName, methodName, ...args) {
        console.log(`[JS Interop] Calling: ${methodName} in ${assemblyName}`, "Args:", args);
        return originalInvoke.apply(this, [assemblyName, methodName, ...args]);
        };
        })();
    </script>
}

<div class="page @(Ready) @(string.Join(" ", ClassNames))">
    @if (FirstTimeLoad || DefaultLayout == null || StoredAppAssembly == null)
    {
        <div class="cover-container"></div>
        <main class="cover-page">
            <article class="content course-container">
                @*TODO: make this a component that can inject itself into a settings page*@
                <Atrium.Components.PluginsPage />
            </article>
        </main>
    }

    @if (StoredAppAssembly != null)
    {
        <CascadingValue Value="DefaultRoot" Name="@nameof(DefaultRoot)">
            <CascadingValue Value="FirstTimeLoad" Name="@nameof(FirstTimeLoad)">
                <CascadingValue Value="PermissionType" Name="@nameof(PermissionType)">
                    @RenderWithPermission()
                </CascadingValue>
            </CascadingValue>
        </CascadingValue>
    }
</div>


@code {
    
    private List<string> GivenClassNames { get; set; } = [];
    public ClassNameCollection CombinedClassNames { get; } = [];
    public ClassNameCollection ClassNames { get => CombinedClassNames; set => GivenClassNames = [.. value]; }
    private List<string>? PageClasses = [];
    public string? Theme;
    public string? Sidebar { get; private set; }
    public string? Background;
    
    // TODO: move this to mainloader classes along side SetTitle
    public void SetPageClasses(List<string> classes)
    {
        PageClasses = classes;
    }

    public void SetTheme(string? classes)
    {
        var newClass = "theme-" + (classes?.ToLowerInvariant() ?? string.Empty);
        Theme = newClass;
    }

    public void SetSidebar(string? classes)
    {
        Sidebar = classes;
    }

    public void SetBackground(string? classes)
    {
        var newClass = "background-" + (classes?.ToLowerInvariant() ?? string.Empty);
        Background = newClass;
    }

    private void SetBackground(AnimationMode? theme)
    {
        var newClass = "background-" + (theme?.ToString()?.ToLowerInvariant() ?? string.Empty);
        Background = newClass;
    }

    private RenderFragment RenderWithLayout() => __builder =>
    {
        <Router AppAssembly="@StoredAppAssembly" AdditionalAssemblies="@(((TrustedLoader)Trust).EnabledAssMappings)">
            <Found Context="routeData">
                @if (AuthService != null)
                {
                    @CreatePermissionContent(routeData)
                }
                else
                {
                    <RouteView RouteData="routeData" DefaultLayout="@DefaultLayout" />
                    <FocusOnNavigate RouteData="routeData" Selector="h1" />
                }
            </Found>
            <NotFound>
                <LayoutView Layout="DefaultLayout">
                    @BuildNotFound()
                </LayoutView>
            </NotFound>
        </Router>
    };

    private RenderFragment RenderWithoutLayout() => __builder =>
    {
        <Router AppAssembly="@StoredAppAssembly" AdditionalAssemblies="@(((TrustedLoader)Trust).EnabledAssMappings)">
            <Found Context="routeData">
                @if (AuthService != null)
                {
                    @CreatePermissionContent(routeData)
                }
                else
                {
                    <RouteView RouteData="routeData" />
                    <FocusOnNavigate RouteData="routeData" Selector="h1" />
                }
            </Found>
            <NotFound>
                @BuildNotFound()
            </NotFound>
        </Router>
        
    };


}